<% content_for :page_title, "パスワードの再設定" %>
<% content_for :hide_user_icon, true %>

<div class="min-h-screen bg-white flex flex-col">
  <div class="flex flex-col items-center px-6 pt-8 pb-6">

    <h1 class="text-lg font-bold text-gray-900 mb-6">新しいパスワードを設定</h1>
    
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="w-full mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" do %>
          新しいパスワード<span class="text-red-500 ml-0.5">*</span>
        <% end %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "新しいパスワードを入力",
              class: "w-full pl-10 pr-10 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        </div>

        <div class="mt-2 p-3 bg-amber-50 border border-amber-200 rounded-lg">
          <div class="flex items-center gap-1.5 mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <p class="text-xs font-medium text-amber-700">セキュリティ要件</p>
          </div>
          <ul class="text-xs text-gray-600 space-y-0.5 pl-1">
            <li class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0"></span>
              最低8文字以上の長さ
            </li>
          </ul>
        </div>
      </div>

      <div class="w-full mb-8">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" do %>
          新しいパスワード（確認）<span class="text-red-500 ml-0.5">*</span>
        <% end %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "もう一度入力してください",
              class: "w-full pl-10 pr-10 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        </div>
      </div>

      <div class="w-full mb-4">
        <%= f.submit "更新する",
            class: "w-full py-3 bg-amber-600 text-white text-sm font-medium rounded-lg hover:bg-amber-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <div class="text-center">
      <%= link_to "キャンセル", new_user_session_path, class: "text-sm text-gray-500 hover:underline" %>
    </div>

  </div>
</div>
