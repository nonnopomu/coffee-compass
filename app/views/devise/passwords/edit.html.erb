<% content_for :page_title, t("views.devise.passwords.edit.page_title") %>
<% content_for :back_path, new_user_session_path %>
<% content_for :hide_user_icon, true %>
<% content_for :page_bg, "bg-amber-50" %>

<div class="flex flex-1 flex-col items-center bg-amber-50 px-5 pt-8 pb-8">
  <div class="flex min-h-[680px] w-full max-w-md flex-col items-center rounded-3xl border border-amber-100 bg-white px-5 py-8 shadow-[0_4px_18px_rgba(90,51,24,0.08)]">
    <div class="mb-5 h-16 w-16 rounded-2xl border border-amber-100 bg-amber-50 p-1.5 shadow-sm">
      <%= image_tag "coffee_compass_orbit_transparent.png", alt: t("app.name"), class: "h-full w-full object-contain" %>
    </div>

    <p class="brand-wordmark mb-7 text-2xl font-bold text-[#5a3318]"><%= t("app.name") %></p>

    <div class="mb-8 w-full max-w-[340px] text-center">
      <h1 class="mb-3 text-xl font-bold text-gray-900"><%= t("views.devise.passwords.edit.title") %></h1>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "w-full max-w-[340px]" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="mb-4 w-full">
        <%= f.label :password, class: "mb-1 block text-sm font-medium text-gray-700" do %>
          <%= t("views.devise.passwords.edit.new_password") %><span class="text-red-500 ml-0.5">*</span>
        <% end %>
        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-3 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: t("views.devise.passwords.edit.new_password_placeholder"), required: true, minlength: Devise.password_length.min,
              class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>

        <div class="mt-3 rounded-xl border border-amber-200 bg-amber-50 p-3">
          <div class="mb-1 flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <p class="text-xs font-medium text-amber-700"><%= t("views.devise.passwords.edit.security_heading") %></p>
          </div>
          <ul class="space-y-0.5 pl-1 text-xs text-gray-600">
            <li class="flex items-center gap-1.5">
              <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-gray-400"></span>
              <%= t("views.devise.passwords.edit.minimum_length") %>
            </li>
          </ul>
        </div>
      </div>

      <div class="mb-8 w-full">
        <%= f.label :password_confirmation, class: "mb-1 block text-sm font-medium text-gray-700" do %>
          <%= t("views.devise.passwords.edit.confirm_password") %><span class="text-red-500 ml-0.5">*</span>
        <% end %>
        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-3 flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: t("views.devise.passwords.edit.confirm_password_placeholder"), required: true, minlength: Devise.password_length.min,
              class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>
      </div>

      <div class="mb-4 w-full">
        <%= f.submit t("views.common.update"),
            class: "w-full cursor-pointer rounded-xl bg-amber-600 py-3 text-sm font-semibold text-white transition-colors hover:bg-amber-700" %>
      </div>
    <% end %>

    <div class="text-center">
      <%= link_to t("views.common.cancel"), new_user_session_path, class: "text-sm text-amber-600 hover:underline" %>
    </div>
  </div>
</div>
