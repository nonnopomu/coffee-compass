<% content_for :page_title, "パスワードの再設定" %>
<% content_for :back_path, new_user_session_path %>
<% content_for :hide_user_icon, true %>

<div class="min-h-screen bg-white flex flex-col">
  <div class="flex flex-col items-center px-6 pt-10 pb-6">

    <div class="w-20 h-20 bg-amber-100 rounded-full flex items-center justify-center mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
      </svg>
    </div>

    <h1 class="text-xl font-bold text-gray-900 mb-3">メールアドレスを確認</h1>
    <p class="text-sm text-gray-500 text-center mb-8">パスワードを再設定するためのメールをお送り<br>します。登録済みのメールアドレスを入力して<br>ください。</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="w-full mb-6">
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@coffee.com",
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        </div>
      </div>

      <div class="w-full mb-4">
        <%= f.submit "送信する",
            class: "w-full py-3 bg-amber-600 text-white text-sm font-medium rounded-lg hover:bg-amber-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <div class="mb-8">
      <%= link_to "キャンセルしてログインへ戻る", new_user_session_path, class: "text-sm text-amber-600 hover:underline" %>
    </div>


  </div>
</div>
