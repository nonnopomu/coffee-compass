<% content_for :page_title, t("views.devise.registrations.edit.page_title") %>
<% content_for :back_path, mypage_path %>
<% content_for :page_bg, "bg-amber-50" %>

<div class="flex flex-1 flex-col items-center bg-amber-50 px-5 pt-8 pb-8">
  <div class="w-full max-w-md rounded-3xl border border-amber-100 bg-white px-5 py-8 shadow-[0_4px_18px_rgba(90,51,24,0.08)]">
    <div class="mx-auto mb-5 h-16 w-16 rounded-2xl border border-amber-100 bg-amber-50 p-1.5 shadow-sm">
      <%= image_tag "coffee_compass_orbit_transparent.webp",
                    alt: t("app.name"),
                    class: "h-full w-full object-contain",
                    decoding: "async",
                    width: 512,
                    height: 512 %>
    </div>

    <div class="mb-7 text-center">
      <p class="brand-wordmark text-2xl font-bold text-[#5a3318]"><%= t("views.devise.registrations.edit.page_title") %></p>
      <p class="mt-2 text-sm leading-6 text-gray-500"><%= t("views.devise.registrations.edit.description") %></p>
    </div>

    <%= form_for(resource,
                 as: resource_name,
                 url: registration_path(resource_name),
                 html: {
                   method: :put,
                   class: "space-y-6",
                   data: {
                     controller: "form-submit",
                     action: "turbo:submit-start->form-submit#disable",
                     form_submit_disabled_text_value: t("views.common.submitting")
                   }
                 }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <section class="rounded-2xl border border-gray-200 bg-white px-4 py-5">
        <div class="mb-4">
          <p class="text-sm font-bold text-gray-900"><%= t("views.devise.registrations.edit.email_section") %></p>
          <p class="mt-1 text-xs leading-5 text-gray-500"><%= t("views.devise.registrations.edit.email_description") %></p>
        </div>

        <div class="w-full">
          <%= f.label :email, class: "sr-only" %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-3 flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <%= f.email_field :email,
                              autofocus: true,
                              autocomplete: "email",
                              required: true,
                              disabled: resource.google_oauth_user?,
                              class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100 disabled:bg-gray-50 disabled:text-gray-500" %>
          </div>
          <% if resource.google_oauth_user? %>
            <p class="mt-2 text-xs leading-5 text-amber-700"><%= t("views.devise.registrations.edit.google_email_locked") %></p>
          <% end %>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p class="mt-3 rounded-lg bg-amber-50 px-3 py-2 text-xs font-medium text-amber-700">
            <%= t("views.devise.registrations.edit.waiting_confirmation", email: resource.unconfirmed_email) %>
          </p>
        <% end %>
      </section>

      <% unless resource.google_oauth_user? %>
        <section class="rounded-2xl border border-gray-200 bg-white px-4 py-5">
          <%= f.label :current_password, class: "mb-1 block text-sm font-medium text-gray-700" %>
          <div class="relative">
            <div class="pointer-events-none absolute inset-y-0 left-3 flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c.828 0 1.5.672 1.5 1.5S12.828 14 12 14s-1.5-.672-1.5-1.5S11.172 11 12 11zm0-7a4 4 0 00-4 4v2H7a2 2 0 00-2 2v7a2 2 0 002 2h10a2 2 0 002-2v-7a2 2 0 00-2-2h-1V8a4 4 0 00-4-4zm-2 6V8a2 2 0 114 0v2h-4z" />
              </svg>
            </div>
            <%= f.password_field :current_password,
                                 autocomplete: "current-password",
                                 required: true,
                                 class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
          </div>
          <p class="mt-2 text-xs leading-5 text-gray-500"><%= t("views.devise.registrations.edit.current_password_help") %></p>
        </section>
      <% end %>

      <div class="<%= resource.google_oauth_user? ? "pb-2" : "grid grid-cols-2 gap-3 pb-2" %>">
        <%= link_to t("views.common.cancel"), mypage_path, class: "block rounded-xl border border-gray-200 bg-white px-4 py-3 text-center text-sm font-semibold text-gray-700" %>
        <% unless resource.google_oauth_user? %>
          <%= f.submit t("views.common.update"),
                       data: { form_submit_target: "submitButton" },
                       class: "cursor-pointer rounded-xl bg-amber-600 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-amber-700 disabled:cursor-not-allowed disabled:opacity-70" %>
        <% end %>
      </div>
    <% end %>

    <section class="mt-5 border-t border-gray-100 pt-4" data-controller="destructive-confirmation">
      <p class="text-xs font-semibold text-gray-500"><%= t("views.devise.registrations.edit.delete_section") %></p>

      <%= form_with url: registration_path(resource_name),
                    method: :delete,
                    data: {
                      controller: "form-submit",
                      action: "turbo:submit-start->form-submit#disable",
                      form_submit_disabled_text_value: t("views.common.submitting")
                    },
                    class: "mt-3 space-y-3" do %>
        <label class="flex items-start gap-2 rounded-xl border border-gray-100 bg-gray-50 px-3 py-3 text-xs leading-5 text-gray-600">
          <%= check_box_tag :confirm_account_deletion,
                            "1",
                            false,
                            required: true,
                            data: {
                              destructive_confirmation_target: "checkbox",
                              action: "change->destructive-confirmation#toggle"
                            },
                            class: "mt-0.5 h-4 w-4 rounded border-gray-300 text-red-600 focus:ring-red-100" %>
          <span><%= t("views.devise.registrations.edit.delete_agreement") %></span>
        </label>

        <%= submit_tag t("views.devise.registrations.edit.delete_button"),
                       disabled: true,
                         data: {
                           destructive_confirmation_target: "submit",
                           form_submit_target: "submitButton",
                           turbo_confirm: t("views.devise.registrations.edit.delete_confirm")
                         },
                       class: "w-full rounded-xl border border-red-200 bg-red-50 px-4 py-2.5 text-sm font-semibold text-red-700 transition-colors hover:bg-red-100 disabled:cursor-not-allowed disabled:border-gray-200 disabled:bg-gray-100 disabled:text-gray-400 disabled:hover:bg-gray-100" %>
      <% end %>
    </section>
  </div>
</div>
