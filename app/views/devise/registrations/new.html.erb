<% content_for :page_title, t("views.devise.registrations.new.page_title") %>
<% content_for :back_path, root_path %>
<% content_for :hide_user_icon, true %>
<% content_for :page_bg, "bg-amber-50" %>

<div class="flex flex-1 flex-col items-center bg-amber-50 px-5 pt-8 pb-8">
  <div class="flex min-h-[760px] w-full max-w-md flex-col items-center rounded-3xl border border-amber-100 bg-white px-5 py-8 shadow-[0_4px_18px_rgba(90,51,24,0.08)]">
    <div class="mb-5 h-16 w-16 rounded-2xl border border-amber-100 bg-amber-50 p-1.5 shadow-sm">
      <%= image_tag "coffee_compass_orbit_transparent.webp",
                    alt: t("app.name"),
                    class: "h-full w-full object-contain",
                    decoding: "async",
                    width: 512,
                    height: 512 %>
    </div>

    <p class="brand-wordmark mb-7 text-2xl font-bold text-[#5a3318]"><%= t("app.name") %></p>

    <%= render "devise/shared/auth_tabs", active: :sign_up %>

    <div class="flex w-full flex-col items-center px-6">
      <div class="mb-4 grid w-full max-w-[340px] grid-cols-[1fr_auto_1fr] items-center gap-2 sm:gap-3">
        <div class="h-px bg-amber-100"></div>
        <div class="flex items-center justify-center gap-2">
          <span class="rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-[11px] font-bold text-amber-700">
            <%= t("views.devise.omniauth.recommended") %>
          </span>
          <p class="text-sm font-bold text-[#5a3318]"><%= t("views.devise.omniauth.easy_sign_up") %></p>
        </div>
        <div class="h-px bg-amber-100"></div>
      </div>

      <%= button_to user_google_oauth2_omniauth_authorize_path(return_to: params[:return_to]),
          method: :post,
          data: { turbo: false },
          form_class: "w-full max-w-[340px]",
          class: "flex w-full items-center justify-center gap-3 rounded-2xl border border-amber-200 bg-white px-4 py-4 text-sm font-bold text-amber-900 shadow-sm transition-colors hover:bg-amber-50 cursor-pointer" do %>
        <%= image_tag "google_logo_g_logo_icon.webp",
                      alt: "",
                      class: "h-5 w-5 object-contain",
                      decoding: "async",
                      width: 20,
                      height: 20 %>
        <span><%= t("views.devise.omniauth.google_sign_up") %></span>
      <% end %>
      <p class="mt-2 max-w-[320px] text-center text-xs font-medium leading-relaxed text-amber-700"><%= t("views.devise.omniauth.google_help") %></p>

      <div class="my-6 flex w-full max-w-[340px] items-center gap-3">
        <div class="h-px flex-1 bg-gray-200"></div>
        <span class="shrink-0 text-xs font-bold text-gray-500"><%= t("views.devise.omniauth.email_sign_up") %></span>
        <div class="h-px flex-1 bg-gray-200"></div>
      </div>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "w-full max-w-[340px]" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>

      <div class="w-full mb-4">
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <%= f.text_field :name, placeholder: t("views.devise.registrations.new.name_placeholder"), autofocus: true, required: true,
              class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>
      </div>

      <div class="w-full mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <%= f.email_field :email, placeholder: "coffee@example.com", autocomplete: "email", required: true,
              class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>
      </div>

      <div class="w-full mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password, placeholder: t("views.devise.registrations.new.password_placeholder"), autocomplete: "new-password", required: true, minlength: Devise.password_length.min,
              class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>
      </div>

      <div class="w-full mb-6">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <%= f.password_field :password_confirmation, placeholder: t("views.devise.registrations.new.password_confirmation_placeholder"), autocomplete: "new-password", required: true, minlength: Devise.password_length.min,
              class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>
      </div>

      <div class="w-full">
        <%= f.submit t("views.devise.registrations.new.submit"),
            class: "w-full rounded-xl bg-amber-600 py-3 text-sm font-semibold text-white transition-colors hover:bg-amber-700 cursor-pointer" %>
      </div>
    <% end %>

    <p class="mt-5 max-w-[340px] text-center text-xs font-medium leading-relaxed text-gray-500">
      <%= t("views.devise.registrations.new.agreement_prefix") %>
      <%= link_to t("views.shared.footer.terms"), terms_path(return_to: request.fullpath), class: "font-bold text-amber-700 underline decoration-amber-300 underline-offset-2" %>
      <%= t("views.devise.registrations.new.agreement_middle") %>
      <%= link_to t("views.shared.footer.privacy"), privacy_path(return_to: request.fullpath), class: "font-bold text-amber-700 underline decoration-amber-300 underline-offset-2" %>
      <%= t("views.devise.registrations.new.agreement_suffix") %>
    </p>
  </div>
</div>
