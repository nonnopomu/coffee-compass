<% content_for :page_title, t("views.devise.registrations.new.page_title") %>
<% content_for :back_path, root_path %>
<% content_for :hide_user_icon, true %>

<div class="flex flex-col items-center px-6 pt-8 pb-6">
    <div class="mb-4 h-16 w-16">
      <%= image_tag "coffee_compass_orbit_transparent.png", alt: t("app.name"), class: "h-full w-full object-contain" %>
    </div>

    <h2 class="text-xl font-bold text-gray-900 mb-1"><%= t("views.devise.registrations.new.title") %></h2>
    <p class="text-sm text-gray-500 text-center mb-8"><%= t("views.devise.registrations.new.tagline") %></p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>

      <div class="w-full mb-4">
        <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <%= f.text_field :name, placeholder: t("views.devise.registrations.new.name_placeholder"), autofocus: true,
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
        </div>
      </div>

      <div class="w-full mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <%= f.email_field :email, placeholder: "coffee@example.com", autocomplete: "email",
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
        </div>
      </div>

      <div class="w-full mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password, placeholder: t("views.devise.registrations.new.password_placeholder"), autocomplete: "new-password",
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
        </div>
      </div>

      <div class="w-full mb-6">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <%= f.password_field :password_confirmation, placeholder: t("views.devise.registrations.new.password_confirmation_placeholder"), autocomplete: "new-password",
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
        </div>
      </div>

      <div class="w-full">
        <%= f.submit t("views.devise.registrations.new.submit"),
            class: "w-full py-3 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <div class="my-6 flex w-full items-center gap-3">
      <div class="h-px flex-1 bg-gray-200"></div>
      <span class="text-xs font-medium text-gray-400"><%= t("views.devise.omniauth.separator") %></span>
      <div class="h-px flex-1 bg-gray-200"></div>
    </div>

    <%= button_to user_google_oauth2_omniauth_authorize_path(return_to: params[:return_to]),
        method: :post,
        data: { turbo: false },
        class: "flex w-full items-center justify-center gap-3 rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm font-medium text-gray-700 shadow-sm transition-colors hover:bg-gray-50 cursor-pointer" do %>
      <span class="flex h-5 w-5 items-center justify-center rounded-full bg-white text-sm font-bold text-blue-600">G</span>
      <%= t("views.devise.omniauth.google") %>
    <% end %>

    <div class="mt-6 text-center">
      <p class="text-sm text-gray-500"><%= t("views.devise.registrations.new.already_have_account") %></p>
      <%= link_to t("views.devise.registrations.new.login_link"), new_user_session_path(return_to: params[:return_to]), class: "text-sm font-medium text-gray-900 border border-gray-200 rounded-full px-6 py-2 mt-2 inline-block hover:bg-gray-50 transition-colors" %>
    </div>
  </div>
