<% content_for :page_title, "新規登録" %>
<% content_for :back_path, root_path %>
<% content_for :hide_user_icon, true %>

<div class="min-h-screen bg-white flex flex-col">

  <div class="flex flex-col items-center px-6 pt-8 pb-6">
    <div class="w-16 h-16 bg-gray-900 rounded-full flex items-center justify-center mb-4">
      <span class="text-white text-lg font-bold tracking-tight">CC</span>
    </div>

    <h2 class="text-xl font-bold text-gray-900 mb-1">Coffee Compassへようこそ</h2>
    <p class="text-sm text-gray-500 text-center mb-8">あなたのお気に入りの一杯を記録し、最高の<br>カフェ体験を共有しましょう。</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="w-full mb-4">
        <%= f.label :name, "ユーザー名", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <%= f.text_field :name, placeholder: "例: コーヒー太郎", autofocus: true,
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
        </div>
      </div>

      <div class="w-full mb-4">
        <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <%= f.email_field :email, placeholder: "coffee@example.com", autocomplete: "email",
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
        </div>
      </div>

      <div class="w-full mb-4">
        <%= f.label :password, "パスワード", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password, placeholder: "8文字以上の半角英数字", autocomplete: "new-password",
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
        </div>
      </div>

      <div class="w-full mb-6">
        <%= f.label :password_confirmation, "パスワード（確認用）", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <%= f.password_field :password_confirmation, placeholder: "パスワードを再入力", autocomplete: "new-password",
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900" %>
        </div>
      </div>

      <div class="w-full">
        <%= f.submit "アカウントを作成する",
            class: "w-full py-3 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <p class="text-sm text-gray-500">すでにアカウントをお持ちですか？</p>
      <%= link_to "ログインはこちら ›", new_user_session_path, class: "text-sm font-medium text-gray-900 border border-gray-200 rounded-full px-6 py-2 mt-2 inline-block hover:bg-gray-50 transition-colors" %>
    </div>
  </div>
</div>
