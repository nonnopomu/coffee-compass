<% content_for :page_title, t("views.devise.sessions.new.page_title") %>
<% content_for :back_path, root_path %>
<% content_for :hide_user_icon, true %>
<% content_for :page_bg, "bg-amber-50" %>

<div class="flex flex-1 flex-col items-center bg-amber-50 px-5 pt-8 pb-8">
  <div class="flex min-h-[760px] w-full max-w-md flex-col items-center rounded-3xl border border-amber-100 bg-white px-5 py-8 shadow-[0_4px_18px_rgba(90,51,24,0.08)]">
    <div class="mb-5 h-16 w-16 rounded-2xl border border-amber-100 bg-amber-50 p-1.5 shadow-sm">
      <%= image_tag "coffee_compass_orbit_transparent.webp",
                    alt: t("app.name"),
                    class: "h-full w-full object-contain",
                    decoding: "async",
                    width: 512,
                    height: 512 %>
    </div>

    <p class="brand-wordmark mb-7 text-2xl font-bold text-[#5a3318]"><%= t("app.name") %></p>

    <%= render "devise/shared/auth_tabs", active: :login %>

    <div class="flex w-full flex-col items-center px-6">
      <div class="mb-4 grid w-full max-w-[340px] grid-cols-[1fr_auto_1fr] items-center gap-2 sm:gap-3">
        <div class="h-px bg-amber-100"></div>
        <div class="flex items-center justify-center gap-2">
          <span class="rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-[11px] font-bold text-amber-700">
            <%= t("views.devise.omniauth.recommended") %>
          </span>
          <p class="text-sm font-bold text-[#5a3318]"><%= t("views.devise.omniauth.easy_login") %></p>
        </div>
        <div class="h-px bg-amber-100"></div>
      </div>

      <%= button_to user_google_oauth2_omniauth_authorize_path(return_to: params[:return_to]),
          method: :post,
          data: { turbo: false, form_submit_target: "submitButton" },
          form: {
            data: {
              controller: "form-submit",
              action: "submit->form-submit#disable",
              form_submit_disabled_text_value: t("views.common.submitting")
            }
          },
          form_class: "w-full max-w-[340px]",
          class: "flex w-full items-center justify-center gap-3 rounded-2xl border border-amber-200 bg-white px-4 py-4 text-sm font-bold text-amber-900 shadow-sm transition-colors hover:bg-amber-50 cursor-pointer disabled:cursor-not-allowed disabled:opacity-70" do %>
        <%= image_tag "google_logo_g_logo_icon.webp",
                      alt: "",
                      class: "h-5 w-5 object-contain",
                      decoding: "async",
                      width: 20,
                      height: 20 %>
        <span><%= t("views.devise.omniauth.google") %></span>
      <% end %>
      <p class="mt-2 max-w-[320px] text-center text-xs font-medium leading-relaxed text-amber-700"><%= t("views.devise.omniauth.google_login_help") %></p>

      <div class="my-6 flex w-full max-w-[340px] items-center gap-3">
        <div class="h-px flex-1 bg-gray-200"></div>
        <span class="shrink-0 text-xs font-bold text-gray-500"><%= t("views.devise.omniauth.email_login") %></span>
        <div class="h-px flex-1 bg-gray-200"></div>
      </div>
    </div>

    <%= form_for(resource,
                 as: resource_name,
                 url: session_path(resource_name),
                 html: {
                   class: "w-full max-w-[340px]",
                   data: {
                     controller: "form-submit",
                     action: "turbo:submit-start->form-submit#disable",
                     form_submit_disabled_text_value: t("views.common.submitting")
                   }
                 }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>

      <div class="w-full mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <%= f.email_field :email, placeholder: "example@coffee.com", autofocus: true, autocomplete: "email", required: true,
              class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>
      </div>

      <div class="w-full mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password, autocomplete: "current-password", required: true, minlength: Devise.password_length.min,
              class: "w-full rounded-xl border border-gray-200 bg-white py-3 pl-10 pr-4 text-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>
      </div>

      <div class="mb-5 w-full">
        <%= f.label :remember_me, class: "flex cursor-pointer items-center gap-2 text-sm font-medium text-gray-700" do %>
          <%= f.check_box :remember_me,
              class: "h-4 w-4 rounded border-gray-300 text-amber-600 focus:ring-amber-500" %>
          <span><%= t("views.devise.sessions.new.remember_me") %></span>
        <% end %>
      </div>

      <div class="w-full mb-3">
        <%= f.submit t("views.shared.header.login"),
            data: { form_submit_target: "submitButton" },
            class: "w-full rounded-xl bg-amber-600 py-3 text-sm font-semibold text-white transition-colors hover:bg-amber-700 cursor-pointer disabled:cursor-not-allowed disabled:opacity-70" %>
      </div>
    <% end %>

    <div class="mt-1">
      <%= link_to t("views.devise.sessions.new.forgot_password"), new_user_password_path, class: "text-sm text-amber-600 hover:underline" %>
    </div>
  </div>
</div>
