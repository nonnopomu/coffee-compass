<% content_for :page_title, t("views.devise.sessions.new.page_title") %>
<% content_for :back_path, root_path %>
<% content_for :hide_user_icon, true %>

<div class="flex flex-col items-center px-6 pt-8 pb-6">
    <div class="mb-6 h-16 w-16">
      <%= image_tag "coffee_compass_orbit_transparent.png", alt: t("app.name"), class: "h-full w-full object-contain" %>
    </div>

    <p class="text-sm text-gray-500 text-center mb-8"><%= t("views.devise.sessions.new.tagline") %></p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>

      <div class="w-full mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <%= f.email_field :email, placeholder: "example@coffee.com", autofocus: true, autocomplete: "email",
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        </div>
      </div>

      <div class="w-full mb-6">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative">
          <div class="absolute inset-y-0 left-3 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full pl-10 pr-4 py-3 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-amber-500" %>
        </div>
      </div>

      <div class="w-full mb-3">
        <%= f.submit t("views.shared.header.login"),
            class: "w-full py-3 bg-amber-600 text-white text-sm font-medium rounded-lg hover:bg-amber-700 transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <div class="mb-8">
      <%= link_to t("views.devise.sessions.new.forgot_password"), new_user_password_path, class: "text-sm text-amber-600 hover:underline" %>
    </div>

    <div class="w-full text-center mb-4">
      <p class="text-sm text-gray-400"><%= t("views.devise.sessions.new.first_time") %></p>
    </div>

    <%= link_to new_user_registration_path(return_to: params[:return_to]), class: "inline-flex items-center justify-center gap-2 px-8 py-3 border border-amber-600 text-amber-600 text-sm font-medium rounded-lg hover:bg-amber-50 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <%= t("views.devise.sessions.new.sign_up") %>
    <% end %>
  </div>
