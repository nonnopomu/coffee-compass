<% active_tab = local_assigns.fetch(:active) %>
<% tab_base_class = "flex-1 px-4 py-3 text-center text-sm font-semibold transition-colors" %>
<% active_class = "bg-amber-600 text-white shadow-sm" %>
<% inactive_class = "text-amber-800 hover:bg-amber-100 hover:text-amber-900" %>

<nav class="mb-5 grid w-full grid-cols-2 overflow-hidden rounded-xl border border-amber-200 bg-amber-50" aria-label="認証メニュー">
  <%= link_to t("views.shared.header.login"),
      new_user_session_path(return_to: params[:return_to]),
      class: "#{tab_base_class} #{active_tab == :login ? active_class : inactive_class}",
      aria: { current: active_tab == :login ? "page" : nil } %>

  <%= link_to t("views.shared.header.sign_up"),
      new_user_registration_path(return_to: params[:return_to]),
      class: "#{tab_base_class} border-l border-amber-200 #{active_tab == :sign_up ? active_class : inactive_class}",
      aria: { current: active_tab == :sign_up ? "page" : nil } %>
</nav>
