<% content_for :header_center do %>
  <div class="flex min-w-0 items-center gap-2">
    <div class="h-9 w-9 flex-shrink-0 rounded-xl border border-amber-100/80 bg-amber-50/85 p-0.5 shadow-sm">
      <%= image_tag "coffee_compass_orbit_transparent.png", alt: t("app.name"), class: "h-full w-full scale-120 object-contain" %>
    </div>
    <span class="brand-wordmark hidden truncate text-lg font-bold sm:inline">Coffee Compass</span>
  </div>
<% end %>

<% content_for :transparent_header, true %>
<% content_for :image_footer, true %>
<% content_for :page_bg, "bg-amber-50" %>

<main class="relative left-1/2 flex-1 w-screen -translate-x-1/2 overflow-hidden bg-transparent px-5 pb-20 sm:px-4">
  <div class="relative mx-auto w-full max-w-screen-sm">
    <section class="pt-32 pb-7 text-center sm:pt-32 lg:pt-36">
      <div class="mx-auto h-24 w-24 sm:h-28 sm:w-28">
        <%= image_tag "coffee_compass_orbit_transparent.png", alt: t("app.name"), class: "h-full w-full object-contain" %>
      </div>
      <h1 class="brand-wordmark mt-4 text-4xl font-bold tracking-normal">Coffee Compass</h1>
      <p class="mt-2 text-sm font-semibold text-amber-700"><%= t("views.pages.top.lead") %></p>
    </section>

    <section class="mx-auto mt-1 max-w-[38rem] rounded-2xl border border-amber-100 bg-white/95 p-3 shadow-[0_1px_8px_rgba(90,51,24,0.08)] sm:mt-5">
      <div class="grid grid-cols-3 overflow-hidden rounded-xl border border-amber-200 bg-amber-50 text-center text-xs font-semibold">
        <div class="flex min-h-12 items-center justify-center bg-amber-600 px-2 text-white">
          <%= t("views.pages.top.keyword_search") %>
        </div>

        <%= link_to t("views.pages.top.area_search"),
                    area_searches_path,
                    class: "flex min-h-12 items-center justify-center border-l border-amber-200 px-2 text-amber-800 transition-colors hover:bg-amber-600 hover:text-white" %>

        <%= link_to t("views.pages.top.tag_search"),
                    tag_searches_path,
                    class: "flex min-h-12 items-center justify-center border-l border-amber-200 px-2 text-amber-800 transition-colors hover:bg-amber-600 hover:text-white" %>
      </div>

      <%# 検索バー：カフェ一覧ページにキーワードをGETパラメーターとして送信する %>
      <%= form_with url: cafes_path, method: :get, data: { turbo: false }, class: "mt-4" do |f| %>
        <div class="flex overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
          <%= f.text_field :keyword,
                           placeholder: t("views.pages.top.keyword_placeholder"),
                           class: "min-w-0 flex-1 bg-white px-4 py-4 text-sm font-medium text-gray-700 placeholder:text-gray-400 focus:outline-none" %>
          <%= f.submit t("views.common.search"),
                       class: "shrink-0 bg-[#8a4300] px-5 text-sm font-semibold text-white cursor-pointer hover:bg-[#6f3400]" %>
        </div>
      <% end %>
    </section>
  </div>
</main>
