<% content_for :page_title, t("views.mypages.show.page_title") %>

<div class="min-h-full bg-gray-50">
  <div class="border-b border-gray-200 bg-white px-4 py-5">
    <div class="flex items-center gap-4">
      <% if current_user.avatar.attached? %>
        <%= image_tag current_user.avatar,
                      alt: t("views.users.show.avatar_alt", name: current_user.name),
                      class: "h-16 w-16 rounded-full border border-amber-100 object-cover shadow-sm" %>
      <% else %>
        <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-amber-100 bg-amber-50 shadow-sm" aria-label="<%= t("views.users.show.avatar_placeholder", name: current_user.name) %>">
          <span class="text-xl font-bold text-amber-700"><%= current_user.name.first %></span>
        </div>
      <% end %>

      <div class="min-w-0">
        <h1 class="break-words text-xl font-bold text-gray-900"><%= current_user.name %></h1>
        <p class="mt-2 break-all text-sm text-gray-500"><%= current_user.email %></p>
      </div>
    </div>

    <div class="mt-4 grid grid-cols-2 gap-3">
      <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
        <p class="text-xs text-gray-500"><%= t("views.mypages.show.recorded_logs") %></p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @drink_logs.size %></p>
      </div>

      <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
        <p class="text-xs text-gray-500"><%= t("views.mypages.show.visited_cafes") %></p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @drink_logs.map(&:cafe_id).uniq.size %></p>
      </div>
    </div>

    <div class="mt-4">
      <%= link_to t("views.common.edit_profile"), edit_profile_path, class: "block rounded-lg bg-amber-600 px-3 py-2 text-center text-sm font-semibold text-white" %>
    </div>
  </div>

  <div class="px-4 py-5 space-y-6">
    <section class="space-y-4">
      <div class="flex items-center gap-3 border-l-4 border-amber-600 pl-3">
        <h2 class="text-sm font-semibold text-gray-900"><%= t("views.mypages.show.my_logs") %></h2>
      </div>

      <% if @drink_logs.any? %>
        <div class="space-y-3">
          <% @drink_logs.each do |drink_log| %>
            <% return_path = mypage_path %>

            <article class="rounded-lg border border-gray-200 bg-white px-4 py-4">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <p class="text-xs font-medium text-amber-600"><%= drink_log.cafe.name %></p>
                  <h3 class="mt-1 break-words text-base font-bold text-gray-900"><%= drink_log.menu_name %></h3>
                  <p class="mt-1 text-xs text-gray-500"><%= l(drink_log.drank_on, format: :long) %></p>
                </div>

                <%= link_to t("views.common.detail"),
                            drink_log_path(drink_log, return_to: return_path),
                            class: "shrink-0 rounded-lg bg-amber-600 px-3 py-2 text-xs font-semibold text-white" %>
              </div>

              <div class="mt-4 grid grid-cols-1 gap-2 text-sm">
                <div class="flex items-start justify-between gap-3">
                  <span class="text-gray-500"><%= DrinkLog.human_attribute_name(:roast_level_tag) %></span>
                  <span class="text-right font-medium text-gray-900"><%= drink_log.roast_level_tag.name %></span>
                </div>

                <div class="flex items-start justify-between gap-3">
                  <span class="text-gray-500"><%= DrinkLog.human_attribute_name(:brew_method_tag) %></span>
                  <span class="text-right font-medium text-gray-900"><%= drink_log.brew_method_tag.name %></span>
                </div>
              </div>

              <div class="mt-3 flex flex-wrap gap-2">
                <% drink_log.taste_tags.each do |tag| %>
                  <span class="rounded-full border border-amber-200 bg-amber-50 px-2.5 py-1 text-xs font-medium text-amber-700"><%= tag.name %></span>
                <% end %>
              </div>

              <% if drink_log.memo.present? %>
                <p class="mt-3 line-clamp-2 whitespace-pre-wrap text-sm leading-6 text-gray-600"><%= drink_log.memo %></p>
              <% end %>

              <div class="mt-4 grid grid-cols-2 gap-2">
                <%= link_to t("views.common.edit_action"),
                            edit_drink_log_path(drink_log, return_to: return_path),
                            class: "rounded-lg border border-amber-600 bg-white px-3 py-2 text-center text-sm font-semibold text-amber-700" %>
                <%= link_to t("views.common.delete_action"),
                            drink_log_path(drink_log, return_to: return_path),
                            data: { turbo_method: :delete, turbo_confirm: t("views.common.delete_log_confirm") },
                            class: "rounded-lg border border-red-200 bg-white px-3 py-2 text-center text-sm font-semibold text-red-600" %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-lg border border-gray-200 bg-white px-4 py-8 text-center">
          <p class="text-sm font-semibold text-gray-900"><%= t("views.mypages.show.no_logs_title") %></p>
          <p class="mt-2 text-sm leading-6 text-gray-500"><%= t("views.mypages.show.no_logs_body") %></p>
        </div>
      <% end %>
    </section>

  </div>
</div>
