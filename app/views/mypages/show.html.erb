<% content_for :page_title, t("views.mypages.show.page_title") %>
<% content_for :page_bg, "bg-white sm:bg-amber-50" %>

<div class="flex flex-1 flex-col bg-white sm:items-center sm:bg-amber-50 sm:px-5 sm:pt-6 sm:pb-8">
  <div class="w-full bg-white px-4 py-5 sm:max-w-md sm:rounded-3xl sm:border sm:border-amber-100 sm:px-5 sm:py-6 sm:shadow-[0_4px_18px_rgba(90,51,24,0.08)]">
    <div class="border-b border-gray-200 pb-5">
    <div class="flex items-center gap-4">
      <% if current_user.avatar.attached? %>
        <%= image_tag current_user.avatar.variant(resize_to_fill: [ 160, 160 ]),
                      alt: t("views.users.show.avatar_alt", name: current_user.name),
                      class: "h-16 w-16 rounded-full border border-gray-200 object-cover shadow-sm",
                      decoding: "async",
                      width: 160,
                      height: 160 %>
      <% else %>
        <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full border border-gray-200 bg-white shadow-sm" aria-label="<%= t("views.users.show.avatar_placeholder", name: current_user.name) %>">
          <span class="text-xl font-bold text-gray-700"><%= current_user.name.first %></span>
        </div>
      <% end %>

      <div class="min-w-0">
        <h1 class="break-words text-xl font-bold text-[#5a3318]"><%= current_user.name %></h1>
        <p class="mt-2 break-all text-sm text-gray-500"><%= current_user.email %></p>
      </div>
    </div>

    <div class="mt-4 grid grid-cols-2 gap-3">
      <div class="rounded-2xl border border-gray-200 bg-white px-4 py-3">
        <p class="text-xs text-gray-500"><%= t("views.mypages.show.recorded_logs") %></p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @drink_logs.size %></p>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white px-4 py-3">
        <p class="text-xs text-gray-500"><%= t("views.mypages.show.visited_cafes") %></p>
        <p class="mt-1 text-xl font-bold text-gray-900"><%= @drink_logs.map(&:cafe_id).compact.uniq.size %></p>
      </div>
    </div>

    <div class="mt-4">
      <%= link_to t("views.common.edit_profile"), edit_profile_path, class: "block rounded-2xl bg-amber-600 px-3 py-2.5 text-center text-sm font-semibold text-white shadow-sm transition-colors hover:bg-amber-700" %>
    </div>
    </div>

    <div class="space-y-6 pt-5">
    <section class="space-y-4">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-3 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-[#5a3318]"><%= t("views.mypages.show.my_logs") %></h2>
        </div>
        <%= link_to t("views.mypages.show.record_log"),
                    new_drink_log_path(return_to: mypage_path),
                    class: "shrink-0 rounded-2xl bg-amber-600 px-3 py-2 text-xs font-semibold text-white shadow-sm transition-colors hover:bg-amber-700" %>
      </div>

      <% if @drink_logs.any? %>
        <div class="space-y-3">
          <% @drink_logs.each do |drink_log| %>
            <% return_path = mypage_path %>

            <article class="overflow-hidden rounded-2xl border border-gray-200 bg-white">
              <%= link_to drink_log_path(drink_log, return_to: return_path), class: "block px-4 pt-4 pb-3 transition-colors hover:bg-amber-50/40" do %>
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="text-xs font-medium text-amber-600"><%= drink_log.brewed_at_home? ? t("views.drink_logs.home_brewed_place") : drink_log.cafe.name %></p>
                    <h3 class="mt-1 break-words text-base font-bold text-[#5a3318]"><%= drink_log.menu_name %></h3>
                  </div>
                  <div class="shrink-0 text-right text-xs text-gray-500">
                    <span class="font-medium text-gray-700"><%= drink_log.roast_level_tag.name %></span>
                    <span class="mx-1 text-gray-300">/</span>
                    <time datetime="<%= drink_log.drank_on.iso8601 %>">
                      <%= l(drink_log.drank_on, format: :long) %>
                    </time>
                  </div>
                </div>

                <div class="mt-3 flex flex-wrap gap-2">
                  <% drink_log.taste_tags.each do |tag| %>
                    <%= render "shared/taste_tag_badge", tag: tag, size: :xs %>
                  <% end %>
                </div>

                <% if drink_log.image.attached? %>
                  <%= image_tag drink_log.image,
                                alt: drink_log.menu_name,
                                class: "mt-3 aspect-video w-full rounded-lg border border-gray-100 object-cover",
                                loading: "lazy",
                                decoding: "async",
                                width: 640,
                                height: 360 %>
                <% end %>

                <% if drink_log.memo.present? %>
                  <p class="mt-3 line-clamp-2 whitespace-pre-wrap text-sm leading-6 text-gray-600"><%= drink_log.memo %></p>
                <% end %>
              <% end %>

              <div class="flex items-center justify-end gap-4 border-t border-gray-100 px-4 py-3">
                <%= link_to t("views.common.edit_action"),
                            edit_drink_log_path(drink_log, return_to: return_path),
                            class: "text-xs font-semibold text-gray-500 transition-colors hover:text-amber-700" %>
                <%= link_to t("views.common.delete_action"),
                            drink_log_path(drink_log, return_to: return_path),
                            data: { turbo_method: :delete, turbo_confirm: t("views.common.delete_log_confirm") },
                            class: "text-xs font-semibold text-red-500 transition-colors hover:text-red-700" %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-2xl border border-gray-200 bg-white px-4 py-8 text-center">
          <p class="text-sm font-semibold text-gray-900"><%= t("views.mypages.show.no_logs_title") %></p>
          <p class="mt-2 text-sm leading-6 text-gray-500"><%= t("views.mypages.show.no_logs_body") %></p>
        </div>
      <% end %>
    </section>
    </div>
  </div>
</div>
