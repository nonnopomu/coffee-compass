<% content_for :page_title, "エリア選択" %>
<% content_for :back_path, root_path %>
<% content_for :hide_footer, true %>

<div class="flex flex-col min-h-full pb-40" data-controller="area-selection">
  <div class="px-4 py-3 flex items-center gap-2 text-gray-400 text-sm border-b border-gray-100">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
    都道府県から探す
  </div>

  <%= form_with url: cafes_path, method: :get, data: { turbo: false } do |f| %>
    <div class="divide-y divide-gray-100">
      <% SearchesHelper::PREFECTURES_BY_REGION.each do |region, prefectures| %>
        <div class="px-4 py-4">
          <p class="text-sm font-bold text-gray-900 mb-3"><%= region %></p>
          <div class="grid grid-cols-2 gap-3">
            <% prefectures.each do |prefecture| %>
              <% available = @available_prefectures.include?(prefecture) %>
              <label class="flex items-center gap-2 <%= available ? 'cursor-pointer' : 'cursor-not-allowed opacity-40' %>">
                <%= f.check_box :prefectures,
                    { multiple: true,
                      checked: Array(params[:prefectures]).include?(prefecture),
                      disabled: !available,
                      data: available ? { area_selection_target: "checkbox", action: "change->area-selection#update" } : {} },
                    prefecture, nil %>
                <span class="text-sm <%= available ? 'text-gray-700' : 'text-gray-400' %>"><%= prefecture %></span>
              </label>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 px-4 py-4">
      <div class="max-w-screen-sm mx-auto space-y-3">
        <div class="flex items-center gap-2">
          <span class="text-xs text-gray-500">選択中</span>
          <span class="text-xs text-amber-600 font-semibold" data-area-selection-target="count">0</span>
          <span class="text-xs text-gray-500">件</span>
        </div>
        <div class="flex flex-wrap gap-2" data-area-selection-target="chips"></div>
        <%= f.submit "このエリアで検索", class: "w-full py-3 bg-amber-600 text-white text-sm font-semibold rounded-xl cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
