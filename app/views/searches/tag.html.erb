<% content_for :page_title, t("views.searches.tag.page_title") %>
<% content_for :back_path, root_path %>
<% content_for :hide_footer, true %>

<div class="flex flex-col min-h-full pb-40" data-controller="tag-selection">
  <%= form_with url: cafes_path, method: :get, data: { turbo: false } do |f| %>
    <div class="px-4 py-5 space-y-8">
      <%# 提供スタイルセクション %>
      <div>
        <div class="flex items-center gap-2 mb-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h14a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11h2a2 2 0 010 4h-2" />
          </svg>
          <h2 class="text-sm font-semibold text-gray-900"><%= t("views.searches.tag.brew_method_heading") %></h2>
        </div>
        <p class="text-xs text-gray-400 mb-3"><%= t("views.searches.tag.brew_method_description") %></p>
        <div class="flex flex-wrap gap-2">
          <% @brew_method_tags.each do |tag| %>
            <button type="button"
                    data-action="click->tag-selection#toggle"
                    data-tag-selection-target="chip"
                    data-tag-id="<%= tag.id %>"
                    data-tag-name="<%= tag.name %>"
                    data-selected="false"
                    class="border border-gray-200 bg-white text-gray-700 text-sm rounded-full px-4 py-1.5 cursor-pointer">
              <%= tag.name %>
            </button>
            <input type="checkbox" name="tag_ids[]" value="<%= tag.id %>" class="hidden" data-tag-id="<%= tag.id %>">
          <% end %>
        </div>
      </div>

      <%# 店舗の特徴セクション %>
      <div>
        <div class="flex items-center gap-2 mb-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
          <h2 class="text-sm font-semibold text-gray-900"><%= t("views.searches.tag.feature_heading") %></h2>
        </div>
        <p class="text-xs text-gray-400 mb-3"><%= t("views.searches.tag.feature_description") %></p>
        <div class="flex flex-wrap gap-2">
          <% @feature_tags.each do |tag| %>
            <button type="button"
                    data-action="click->tag-selection#toggle"
                    data-tag-selection-target="chip"
                    data-tag-id="<%= tag.id %>"
                    data-tag-name="<%= tag.name %>"
                    data-selected="false"
                    class="border border-gray-200 bg-white text-gray-700 text-sm rounded-full px-4 py-1.5 cursor-pointer">
              <%= tag.name %>
            </button>
            <input type="checkbox" name="tag_ids[]" value="<%= tag.id %>" class="hidden" data-tag-id="<%= tag.id %>">
          <% end %>
        </div>
      </div>

      <%# 検索のヒント %>
      <div class="bg-gray-50 rounded-xl px-4 py-3 flex items-start gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <div>
          <p class="text-xs font-medium text-gray-600 mb-0.5"><%= t("views.searches.tag.hint_heading") %></p>
          <p class="text-xs text-gray-400"><%= t("views.searches.tag.hint_body") %></p>
        </div>
      </div>
    </div>

    <%# 選択中タグ・リセット・検索ボタン：固定フッターに配置 %>
    <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 px-4 py-4">
      <div class="max-w-screen-sm mx-auto space-y-3">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500"><%= t("views.common.selected") %></span>
            <span class="text-xs text-amber-600 font-semibold" data-tag-selection-target="count">0</span>
            <span class="text-xs text-gray-500"><%= t("views.common.count_suffix") %></span>
          </div>
          <button type="button"
                  data-action="click->tag-selection#reset"
                  class="text-xs text-gray-400 cursor-pointer">
            <%= t("views.common.reset") %>
          </button>
        </div>
        <div class="flex flex-wrap gap-2" data-tag-selection-target="selected"></div>
        <%= f.submit t("views.searches.tag.submit"), class: "w-full py-3 bg-amber-600 text-white text-sm font-semibold rounded-xl cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
