<% content_for :page_title, t("views.cafes.show.page_title") %>
<% return_to = params[:return_to].to_s %>
<% safe_back_path = return_to.start_with?("/") && !return_to.start_with?("//") ? return_to : cafes_path %>
<% content_for :back_path, safe_back_path %>

<%# 店舗写真エリア %>
<div class="relative bg-gray-200 aspect-video flex items-center justify-center">
  <% if @cafe.image.attached? %>
    <%= image_tag @cafe.image,
                  alt: @cafe.name,
                  class: "h-full w-full object-cover" %>
  <% else %>
    <%= image_tag "cafe_placeholder.png",
                  alt: "",
                  class: "h-full w-full object-cover" %>
  <% end %>

  <%# 店舗名・エリア：写真の上にオーバーレイで表示 %>
  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent px-4 py-4">
    <p class="text-white/70 text-xs mb-0.5"><%= @cafe.prefecture %></p>
    <h1 class="text-white text-xl font-bold"><%= @cafe.name %></h1>
  </div>
</div>

<%# タブナビゲーション：Stimulusでタブ切り替えを管理する %>
<div data-controller="tabs">
  <%# タブボタン %>
  <div class="flex border-b border-gray-200 bg-white sticky top-16 z-10">
    <button data-tabs-target="tab"
            data-action="click->tabs#switch"
            data-index="0"
            data-tab-key=""
            class="flex-1 py-3 text-sm font-medium text-amber-600 border-b-2 border-amber-600 cursor-pointer">
      <%= t("views.cafes.show.basic_info") %>
    </button>
    <button data-tabs-target="tab"
            data-action="click->tabs#switch"
            data-index="1"
            data-tab-key="logs"
            class="flex-1 py-3 text-sm font-medium text-gray-400 border-b-2 border-transparent cursor-pointer">
      <%= t("views.cafes.show.logs") %>
    </button>
  </div>

  <%# 基本情報パネル %>
  <div data-tabs-target="panel">
    <%= render "basic_info",
               cafe: @cafe,
               roast_level_trends: @roast_level_trends,
               taste_tag_trends: @taste_tag_trends,
               brew_method_trends: @brew_method_trends %>
  </div>

  <%# みんなのログパネル：現時点では空。ログ機能実装時に中身を追加する %>
  <div data-tabs-target="panel" class="hidden">
    <%= render "drink_logs_tab", cafe: @cafe, drink_logs: @drink_logs %>
  </div>
</div>
