<% roast_level_entries = roast_level_trends.sort_by { |tag, _count| [tag.display_order, tag.name] } %>
<% taste_tag_entries = taste_tag_trends.first(5) %>
<% roast_level_total = roast_level_entries.sum { |_tag, count| count } %>
<% log_count = roast_level_total %>
<% roast_level_colors = [ "bg-amber-200", "bg-orange-500", "bg-stone-800" ] %>

<% if roast_level_entries.present? || taste_tag_entries.present? %>
  <section class="rounded-2xl border border-gray-200 bg-white px-4 py-4">
    <div class="flex items-start justify-between gap-3">
      <div class="flex items-start gap-2">
        <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-amber-50 text-amber-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3v18m4-14v14M7 11v10m12-6v6" />
          </svg>
        </span>
        <div>
          <h3 class="text-sm font-semibold text-gray-900"><%= t("views.cafes.log_trends.title") %></h3>
          <% if log_count.positive? %>
            <p class="mt-0.5 text-xs text-gray-500"><%= t("views.cafes.log_trends.summary", count: log_count) %></p>
          <% end %>
        </div>
      </div>

    </div>

    <% if taste_tag_entries.present? %>
      <div class="mt-4 rounded-lg bg-amber-50 px-3 py-3 ring-1 ring-amber-100">
        <div class="flex items-center gap-1.5 text-amber-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M3 11.5V5a2 2 0 012-2h6.5a2 2 0 011.414.586l7.5 7.5a2 2 0 010 2.828l-6.5 6.5a2 2 0 01-2.828 0l-7.5-7.5A2 2 0 013 11.5z" />
          </svg>
          <p class="text-xs font-semibold"><%= t("views.cafes.log_trends.taste_tags") %></p>
        </div>
        <div class="mt-2 flex flex-wrap gap-2">
          <% taste_tag_entries.each do |tag, _count| %>
            <span class="rounded-full bg-white px-2.5 py-1 text-xs font-semibold text-amber-800 ring-1 ring-amber-200">
              <%= tag.name %>
            </span>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if roast_level_entries.present? %>
      <div class="mt-4">
        <div class="mb-2">
          <p class="text-xs font-semibold text-gray-700"><%= t("views.cafes.log_trends.roast_level_distribution") %></p>
        </div>

        <div class="flex h-2.5 overflow-hidden rounded-full bg-white">
          <% roast_level_entries.each_with_index do |(_tag, count), index| %>
            <% percentage = (count.to_f / roast_level_total * 100).round %>
            <div class="<%= roast_level_colors[index] || "bg-stone-500" %>"
                 style="width: <%= percentage %>%"></div>
          <% end %>
        </div>

        <div class="mt-2 grid gap-1.5">
          <% roast_level_entries.each_with_index do |(tag, count), index| %>
            <% percentage = (count.to_f / roast_level_total * 100).round %>
            <div class="flex items-center justify-between gap-3 text-[11px]">
              <div class="flex min-w-0 items-center gap-1.5">
                <span class="h-2 w-2 shrink-0 rounded-full <%= roast_level_colors[index] || "bg-stone-500" %>"></span>
                <span class="truncate text-gray-600"><%= tag.name %></span>
              </div>
              <span class="shrink-0 font-semibold text-gray-700"><%= percentage %>%</span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </section>
<% end %>
