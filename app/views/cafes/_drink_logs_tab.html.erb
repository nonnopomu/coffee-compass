<div class="bg-white px-4 py-5">
  <% if user_signed_in? %>
    <div class="mb-4">
      <%= link_to t("views.cafes.drink_logs_tab.record_this_cafe_log"),
                  new_drink_log_path(cafe_id: cafe.id, return_to: cafe_path(cafe, tab: "logs")),
                  class: "block rounded-2xl bg-amber-600 px-4 py-3 text-center text-sm font-semibold text-white shadow-sm transition-colors hover:bg-amber-700" %>
    </div>
  <% end %>

  <% if drink_logs.any? %>
    <div class="space-y-4">
      <% drink_logs.each do |drink_log| %>
        <article class="rounded-2xl border border-gray-200 bg-white p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs text-gray-500">
                <%= link_to drink_log.user.name, user_path(drink_log.user), class: "font-medium text-amber-700" %>
              </p>
              <h3 class="mt-1 text-base font-bold text-gray-900"><%= drink_log.menu_name %></h3>
            </div>
            <time class="shrink-0 text-xs text-gray-500" datetime="<%= drink_log.created_at.to_date.iso8601 %>">
              <%= l(drink_log.created_at.to_date, format: :long) %>
            </time>
          </div>

          <div class="mt-3 flex flex-wrap gap-2">
            <span class="rounded-full border border-stone-100 bg-stone-50 px-3 py-1 text-xs font-medium text-stone-700"><%= drink_log.roast_level_tag.name %></span>
            <span class="rounded-full border border-stone-100 bg-stone-50 px-3 py-1 text-xs font-medium text-stone-700"><%= drink_log.brew_method_tag.name %></span>
            <% drink_log.taste_tags.each do |tag| %>
              <span class="rounded-full border border-amber-100 bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700"><%= tag.name %></span>
            <% end %>
          </div>

          <% if drink_log.image.attached? %>
            <%= image_tag drink_log.image,
                          alt: drink_log.menu_name,
                          class: "mt-3 aspect-video w-full rounded-lg border border-gray-100 object-cover" %>
          <% end %>

          <% if drink_log.memo.present? %>
            <p class="mt-3 whitespace-pre-wrap text-sm leading-6 text-gray-700"><%= drink_log.memo %></p>
          <% end %>

          <div class="mt-4 flex justify-end">
            <%= link_to t("views.common.show_detail"), drink_log_path(drink_log, return_to: cafe_path(cafe, tab: "logs")), class: "text-sm font-semibold text-amber-700" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-2xl border border-gray-200 bg-white px-4 py-12 text-center">
      <p class="text-sm text-gray-500"><%= t("views.cafes.drink_logs_tab.empty") %></p>
    </div>
  <% end %>
</div>
