<div class="px-4 py-5">
  <% if drink_logs.any? %>
    <div class="space-y-4">
      <% drink_logs.each do |drink_log| %>
        <article class="rounded-lg border border-gray-200 bg-white p-4">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs text-gray-500"><%= drink_log.user.name %></p>
              <h3 class="mt-1 text-base font-bold text-gray-900"><%= drink_log.menu_name %></h3>
            </div>
            <time class="shrink-0 text-xs text-gray-500" datetime="<%= drink_log.created_at.to_date.iso8601 %>">
              <%= l(drink_log.created_at.to_date, format: :long) %>
            </time>
          </div>

          <div class="mt-3 flex flex-wrap gap-2">
            <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600"><%= drink_log.roast_level_tag.name %></span>
            <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600"><%= drink_log.brew_method_tag.name %></span>
            <% drink_log.taste_tags.each do |tag| %>
              <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700"><%= tag.name %></span>
            <% end %>
          </div>

          <% if drink_log.memo.present? %>
            <p class="mt-3 whitespace-pre-wrap text-sm leading-6 text-gray-700"><%= drink_log.memo %></p>
          <% end %>

          <div class="mt-4 flex justify-end">
            <%= link_to t("views.common.show_detail"), drink_log_path(drink_log, return_to: cafe_path(cafe, tab: "logs")), class: "text-sm font-semibold text-amber-700" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="py-12 text-center">
      <p class="text-sm text-gray-500"><%= t("views.cafes.drink_logs_tab.empty") %></p>
    </div>
  <% end %>
</div>
