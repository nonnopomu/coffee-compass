<%= link_to cafe_path(cafe),
            aria: { label: t("views.cafes.cafe_card.open_detail", name: cafe.name) },
            class: "block rounded-3xl border border-stone-200 bg-white px-4 py-4 no-underline shadow-[0_4px_16px_rgba(90,51,24,0.05)]" do %>
  <%# 店舗写真エリア %>
  <div class="relative rounded-2xl overflow-hidden mb-4 bg-amber-50 aspect-video flex items-center justify-center">
    <% if cafe.image.attached? %>
      <%= image_tag cafe.image,
                    alt: cafe.name,
                    class: "h-full w-full object-cover" %>
    <% else %>
      <%= image_tag "cafe_placeholder.png",
                    alt: "",
                    class: "h-full w-full object-cover" %>
    <% end %>

    <%# ログ数バッジ %>
    <span class="absolute top-2 right-2 rounded-full bg-[#5a3318]/80 px-2.5 py-1 text-xs font-semibold text-white">
      <%= t("views.cafes.cafe_card.log_count", count: cafe.drink_logs.size) %>
    </span>
  </div>

  <%# エリア %>
  <p class="mb-0.5 text-xs font-semibold text-amber-700"><%= cafe.prefecture %></p>

  <%# 店舗名 %>
  <h2 class="mb-1 text-base font-bold text-[#5a3318]"><%= cafe.name %></h2>

  <%# 住所 %>
  <p class="mb-2 text-xs text-gray-500"><%= cafe.address %></p>

  <%# 特徴タグ %>
  <% feature_tags = cafe.tags.select(&:cafe_feature?) %>
  <% if feature_tags.any? %>
    <div class="flex flex-wrap gap-1.5 mb-3">
      <% feature_tags.each do |tag| %>
        <span class="rounded-full border border-amber-100 bg-amber-50 px-2.5 py-0.5 text-xs font-medium text-amber-800"><%= tag.name %></span>
      <% end %>
    </div>
  <% end %>

  <%# リンク %>
  <div class="flex items-center pt-1">
    <span class="flex items-center gap-0.5 text-sm font-semibold text-amber-700">
      <%= t("views.common.show_detail") %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </div>
<% end %>
