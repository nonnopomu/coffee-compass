<div class="bg-white px-4 py-4">
  <%# 店舗写真エリア %>
  <div class="relative rounded-xl overflow-hidden mb-3 bg-gray-100 aspect-video flex items-center justify-center">
    <% if cafe.image.attached? %>
      <%= image_tag cafe.image,
                    alt: cafe.name,
                    class: "h-full w-full object-cover" %>
    <% else %>
      <%= image_tag "cafe_placeholder.png",
                    alt: "",
                    class: "h-full w-full object-cover" %>
    <% end %>

    <%# ログ数バッジ %>
    <span class="absolute top-2 right-2 bg-black/60 text-white text-xs px-2.5 py-1 rounded-full font-medium">
      <%= t("views.cafes.cafe_card.log_count", count: cafe.drink_logs.size) %>
    </span>
  </div>

  <%# エリア %>
  <p class="text-xs text-gray-400 mb-0.5"><%= cafe.prefecture %></p>

  <%# 店舗名 %>
  <h2 class="text-base font-bold text-gray-900 mb-1"><%= cafe.name %></h2>

  <%# 住所 %>
  <p class="text-xs text-gray-400 mb-2"><%= cafe.address %></p>

  <%# 特徴タグ %>
  <% feature_tags = cafe.tags.select(&:cafe_feature?) %>
  <% if feature_tags.any? %>
    <div class="flex flex-wrap gap-1.5 mb-3">
      <% feature_tags.each do |tag| %>
        <span class="text-xs text-gray-500 bg-gray-100 rounded-full px-2.5 py-0.5"><%= tag.name %></span>
      <% end %>
    </div>
  <% end %>

  <%# リンク %>
  <div class="flex items-center justify-between pt-1">
    <%= link_to cafe_path(cafe), class: "text-sm text-amber-600 font-medium flex items-center gap-0.5" do %>
      <%= t("views.common.show_detail") %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    <% end %>
    <%= link_to cafe.google_maps_url, target: "_blank", rel: "noopener noreferrer", class: "text-xs text-gray-400 flex items-center gap-1" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      Google Maps
    <% end %>
  </div>
</div>
