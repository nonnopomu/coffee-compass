<% content_for :page_title, t("views.admin.dashboards.show.page_title") %>

<div class="min-h-full bg-gray-50">
  <section class="bg-white px-4 py-5 border-b border-gray-200">
    <p class="text-xs font-semibold text-amber-700"><%= t("views.admin.dashboards.show.menu_label") %></p>
    <h1 class="mt-1 text-xl font-bold text-gray-900"><%= t("views.admin.dashboards.show.title") %></h1>
    <p class="mt-2 text-sm leading-6 text-gray-600">
      <%= t("views.admin.dashboards.show.description") %>
    </p>
  </section>

  <div class="px-4 py-4 space-y-3">
    <%= link_to admin_cafes_path, class: "block rounded-lg border border-gray-200 bg-white px-4 py-4 shadow-sm" do %>
      <div class="flex items-center justify-between gap-3">
        <div class="min-w-0">
          <p class="text-base font-bold text-gray-900"><%= t("views.admin.dashboards.show.cafes_title") %></p>
          <p class="mt-1 text-sm leading-5 text-gray-600"><%= t("views.admin.dashboards.show.cafes_description") %></p>
        </div>

        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-amber-50 text-amber-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </div>
    <% end %>

    <%= link_to admin_tags_path, class: "block rounded-lg border border-gray-200 bg-white px-4 py-4 shadow-sm" do %>
      <div class="flex items-center justify-between gap-3">
        <div class="min-w-0">
          <p class="text-base font-bold text-gray-900"><%= t("views.admin.dashboards.show.tags_title") %></p>
          <p class="mt-1 text-sm leading-5 text-gray-600"><%= t("views.admin.dashboards.show.tags_description") %></p>
        </div>

        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-amber-50 text-amber-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M7 7h.01M7 3h5c.53 0 1.04.21 1.41.59l7 7a2 2 0 010 2.82l-7 7a2 2 0 01-2.82 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" />
          </svg>
        </div>
      </div>
    <% end %>

    <%= link_to "#", class: "block rounded-lg border border-gray-200 bg-white px-4 py-4 shadow-sm" do %>
      <div class="flex items-center justify-between gap-3">
        <div class="min-w-0">
          <p class="text-base font-bold text-gray-900"><%= t("views.admin.dashboards.show.logs_title") %></p>
          <p class="mt-1 text-sm leading-5 text-gray-600"><%= t("views.admin.dashboards.show.logs_description") %></p>
        </div>

        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-amber-50 text-amber-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12h6m-6 4h6m2 4H7a2 2 0 01-2-2V6a2 2 0 012-2h6l6 6v8a2 2 0 01-2 2z" />
          </svg>
        </div>
      </div>
    <% end %>

    <div class="pt-3">
      <%= link_to t("views.common.logout"), destroy_user_session_path, data: { turbo_method: :delete }, class: "block w-full rounded-lg bg-amber-600 px-4 py-3 text-center text-sm font-semibold text-white shadow-sm" %>
    </div>
  </div>
</div>
