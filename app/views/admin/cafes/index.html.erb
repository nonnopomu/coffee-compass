<% content_for :page_title, t("views.admin.cafes.index.page_title") %>
<% content_for :back_path, admin_root_path %>

<div class="bg-gray-50 min-h-full">
  <div class="px-4 py-4 border-b border-gray-200 bg-white">
    <div class="flex items-center justify-between gap-3">
      <div>
        <p class="text-xs text-gray-500"><%= t("views.admin.cafes.index.registered_cafes") %></p>
        <p class="mt-0.5 text-lg font-bold text-gray-900"><%= t("views.common.count", count: @cafes.size) %></p>
      </div>

      <%= link_to new_admin_cafe_path, class: "inline-flex items-center gap-1.5 rounded-lg bg-amber-600 px-3 py-2 text-sm font-semibold text-white" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        <%= t("views.admin.cafes.index.new") %>
      <% end %>
    </div>
  </div>

  <% if @cafes.empty? %>
    <div class="px-6 py-20 text-center">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-gray-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h14a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11h2a2 2 0 010 4h-2" />
        </svg>
      </div>
      <p class="text-sm font-medium text-gray-700"><%= t("views.admin.cafes.index.empty") %></p>
      <%= link_to t("views.admin.cafes.index.create_link"), new_admin_cafe_path, class: "mt-4 inline-flex rounded-lg bg-amber-600 px-4 py-2 text-sm font-semibold text-white" %>
    </div>
  <% else %>
    <div class="divide-y divide-gray-100">
      <% @cafes.each do |cafe| %>
        <article class="bg-white px-4 py-4">
          <div class="flex items-start gap-3">
            <div class="flex h-16 w-20 shrink-0 items-center justify-center overflow-hidden rounded-lg bg-gray-100">
              <% if cafe.image.attached? %>
                <%= image_tag cafe.image,
                              alt: cafe.name,
                              class: "h-full w-full object-cover",
                              loading: "lazy",
                              decoding: "async",
                              width: 320,
                              height: 256 %>
              <% else %>
                <%= image_tag "cafe_placeholder.webp",
                              alt: "",
                              class: "h-full w-full object-cover",
                              loading: "lazy",
                              decoding: "async",
                              width: 320,
                              height: 256 %>
              <% end %>
            </div>

            <div class="min-w-0">
              <div class="mb-1 flex flex-wrap items-center gap-2">
                <h2 class="text-base font-bold text-gray-900"><%= cafe.name %></h2>
                <span class="rounded-full px-2 py-0.5 text-xs font-semibold <%= cafe.published? ? 'bg-green-50 text-green-700' : cafe.closed? ? 'bg-gray-100 text-gray-500' : 'bg-amber-50 text-amber-700' %>">
                  <%= t("enums.cafe.status.#{cafe.status}") %>
                </span>
              </div>

              <p class="text-xs text-gray-500"><%= cafe.prefecture %></p>
              <p class="mt-1 text-sm text-gray-700"><%= cafe.address %></p>
            </div>
          </div>

          <% if cafe.tags.any? %>
            <div class="mt-3 flex flex-wrap gap-1.5">
              <% cafe.tags.each do |tag| %>
                <span class="rounded-full bg-gray-100 px-2.5 py-1 text-xs text-gray-600"><%= tag.name %></span>
              <% end %>
            </div>
          <% end %>

          <div class="mt-4 grid grid-cols-2 gap-2">
            <%= link_to t("views.common.show_detail"), cafe_path(cafe, return_to: admin_cafes_path), class: "rounded-lg border border-gray-200 px-3 py-2 text-center text-sm font-medium text-gray-700" %>
            <%= link_to t("views.common.edit"), edit_admin_cafe_path(cafe, return_to: admin_cafes_path), class: "rounded-lg border border-amber-600 px-3 py-2 text-center text-sm font-semibold text-amber-700" %>
          </div>
        </article>
      <% end %>
    </div>
  <% end %>
</div>
