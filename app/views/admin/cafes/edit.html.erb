<% content_for :page_title, t("views.admin.cafes.edit.page_title") %>
<% return_to = params[:return_to].to_s %>
<% safe_back_path = return_to.start_with?("/") && !return_to.start_with?("//") ? return_to : cafe_path(@cafe) %>
<% content_for :back_path, safe_back_path %>

<%= render "form", cafe: @cafe, prefectures: @prefectures, tags: @tags, submit_label: t("views.common.update"), cancel_path: safe_back_path %>
