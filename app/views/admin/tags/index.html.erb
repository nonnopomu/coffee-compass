<% content_for :page_title, t("views.admin.tags.index.page_title") %>
<% content_for :back_path, admin_root_path %>

<div class="min-h-full bg-gray-50">
  <div class="border-b border-gray-200 bg-white px-4 py-4">
    <div class="flex items-center justify-between gap-3">
      <div>
        <p class="text-xs text-gray-500"><%= t("views.admin.tags.index.registered_tags") %></p>
        <p class="mt-0.5 text-lg font-bold text-gray-900"><%= t("views.common.count", count: @tags.size) %></p>
      </div>

      <%= link_to new_admin_tag_path, class: "inline-flex items-center gap-1.5 rounded-lg bg-amber-600 px-3 py-2 text-sm font-semibold text-white" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        <%= t("views.admin.tags.index.new") %>
      <% end %>
    </div>
  </div>

  <% if @tags.empty? %>
    <div class="px-6 py-20 text-center">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-gray-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.53 0 1.04.21 1.41.59l7 7a2 2 0 010 2.82l-7 7a2 2 0 01-2.82 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" />
        </svg>
      </div>
      <p class="text-sm font-medium text-gray-700"><%= t("views.admin.tags.index.empty") %></p>
      <%= link_to t("views.admin.tags.index.create_link"), new_admin_tag_path, class: "mt-4 inline-flex rounded-lg bg-amber-600 px-4 py-2 text-sm font-semibold text-white" %>
    </div>
  <% else %>
    <div class="space-y-4 px-4 py-4">
      <% @tags.group_by(&:category).each do |category, tags| %>
        <% if category == "taste" %>
          <% parent_tags = tags.select { |tag| tag.parent_id.nil? && tag.beginner_display_order.present? }.sort_by(&:display_order) %>
          <% visible_tags = parent_tags + parent_tags.flat_map(&:children) %>
        <% else %>
          <% visible_tags = tags.select(&:is_active?) %>
        <% end %>
        <section>
          <div class="mb-2 flex items-center justify-between">
            <h2 class="border-l-4 border-amber-600 pl-3 text-sm font-semibold text-gray-900">
              <%= t("enums.tag.category.#{category}") %>
            </h2>
            <span class="text-xs text-gray-400"><%= t("views.common.count", count: visible_tags.size) %></span>
          </div>

          <% if category == "taste" %>
            <div class="space-y-3">
              <% parent_tags.each do |parent_tag| %>
                <% child_tags = parent_tag.children.sort_by(&:display_order) %>
                <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
                  <p class="mb-2 text-xs font-semibold text-gray-500"><%= t("views.admin.tags.index.parent_tag") %></p>
                  <div class="flex items-center justify-between gap-3 rounded-lg border border-gray-100 bg-gray-50 px-3 py-2">
                    <div class="min-w-0 flex items-center gap-2">
                      <% if parent_tag.color_hex.present? %>
                        <span class="h-3 w-3 rounded-full border border-white shadow-sm" style="background-color: <%= parent_tag.color_hex %>"></span>
                      <% end %>
                      <p class="truncate text-sm font-bold text-gray-900"><%= parent_tag.name %></p>
                      <span class="rounded-full px-2 py-0.5 text-xs font-semibold <%= parent_tag.is_active? ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                        <%= t("enums.tag.is_active.#{parent_tag.is_active?}") %>
                      </span>
                    </div>

                    <%= link_to t("views.common.edit"), edit_admin_tag_path(parent_tag), class: "shrink-0 rounded-lg border border-amber-600 px-3 py-1.5 text-xs font-semibold text-amber-700" %>
                  </div>

                  <% if child_tags.any? %>
                    <div class="mt-3 border-t border-gray-100 pt-3">
                      <p class="mb-2 text-xs font-semibold text-gray-500"><%= t("views.admin.tags.index.child_tags") %></p>
                      <div class="space-y-2">
                        <% child_tags.each do |child_tag| %>
                          <div class="flex items-center justify-between gap-3 rounded-lg border px-3 py-2 <%= child_tag.is_active? ? 'border-gray-200 bg-white' : 'border-gray-200 bg-gray-100 text-gray-400' %>">
                            <div class="min-w-0 flex items-center gap-2">
                              <% if child_tag.color_hex.present? %>
                                <span class="h-2.5 w-2.5 rounded-full border border-white shadow-sm <%= 'opacity-50' unless child_tag.is_active? %>" style="background-color: <%= child_tag.color_hex %>"></span>
                              <% end %>
                              <span class="truncate text-xs font-semibold <%= child_tag.is_active? ? 'text-gray-700' : 'text-gray-400' %>"><%= child_tag.name %></span>
                              <span class="rounded-full px-2 py-0.5 text-xs font-semibold <%= child_tag.is_active? ? 'bg-green-50 text-green-700' : 'bg-gray-200 text-gray-500' %>">
                                <%= t("enums.tag.is_active.#{child_tag.is_active?}") %>
                              </span>
                            </div>

                            <%= link_to t("views.common.edit"), edit_admin_tag_path(child_tag), class: "shrink-0 rounded-lg border border-gray-300 px-3 py-1.5 text-xs font-semibold #{child_tag.is_active? ? 'text-gray-700' : 'text-gray-500'}" %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% else %>
                    <p class="mt-3 border-t border-gray-100 pt-3 text-xs text-gray-400"><%= t("views.admin.tags.index.no_child_tags") %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
              <% visible_tags.each do |tag| %>
                <div class="border-b border-gray-100 px-4 py-3 last:border-b-0">
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <div class="flex flex-wrap items-center gap-2">
                        <p class="text-sm font-semibold text-gray-900"><%= tag.name %></p>
                        <span class="rounded-full px-2 py-0.5 text-xs font-semibold <%= tag.is_active? ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                          <%= t("enums.tag.is_active.#{tag.is_active?}") %>
                        </span>
                      </div>
                    </div>

                    <%= link_to t("views.common.edit"), edit_admin_tag_path(tag), class: "shrink-0 rounded-lg border border-amber-600 px-3 py-1.5 text-xs font-semibold text-amber-700" %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </section>
      <% end %>
    </div>
  <% end %>
</div>
