<% content_for :page_title, t("views.profiles.edit.page_title") %>
<% content_for :back_path, mypage_path %>
<% content_for :page_bg, "bg-white sm:bg-amber-50" %>

<div class="flex flex-1 flex-col bg-white sm:items-center sm:bg-amber-50 sm:px-5 sm:pt-6 sm:pb-8">
  <div class="w-full bg-white px-4 py-5 sm:max-w-md sm:rounded-3xl sm:border sm:border-amber-100 sm:px-5 sm:py-6 sm:shadow-[0_4px_18px_rgba(90,51,24,0.08)]">
    <%= form_with model: @user,
                  url: profile_path,
                  method: :patch,
                  data: {
                    controller: "form-submit",
                    action: "turbo:submit-start->form-submit#disable",
                    form_submit_disabled_text_value: t("views.common.submitting")
                  },
                  class: "space-y-6" do |f| %>
      <% if @user.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3">
          <p class="text-sm font-semibold text-red-700"><%= t("views.common.error_heading") %></p>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <section class="rounded-2xl border border-gray-200 bg-white px-4 py-5"
               data-controller="image-crop"
               data-image-crop-output-width-value="512"
               data-image-crop-output-height-value="512"
               data-image-crop-quality-value="0.82"
               data-image-crop-file-name-value="avatar_image"
               data-image-crop-load-error-value="<%= t("views.shared.image_crop.load_error") %>"
               data-image-crop-process-error-value="<%= t("views.shared.image_crop.process_error") %>">
        <div class="flex items-center gap-4">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar,
                          alt: t("views.users.show.avatar_alt", name: @user.name),
                          data: { image_crop_target: "image" },
                          class: "h-20 w-20 shrink-0 rounded-full border border-gray-200 object-cover shadow-sm",
                          decoding: "async",
                          width: 160,
                          height: 160 %>
            <div data-image-crop-target="placeholder" class="hidden h-20 w-20 shrink-0 items-center justify-center rounded-full border border-gray-200 bg-white shadow-sm" aria-label="<%= t("views.users.show.avatar_placeholder", name: @user.name) %>">
              <span class="text-2xl font-bold text-gray-700"><%= @user.name.first %></span>
            </div>
          <% else %>
            <img data-image-crop-target="image"
                 alt="<%= t("views.users.show.avatar_alt", name: @user.name) %>"
                 class="hidden h-20 w-20 shrink-0 rounded-full border border-gray-200 object-cover shadow-sm"
                 decoding="async"
                 width="160"
                 height="160">
            <div data-image-crop-target="placeholder" class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full border border-gray-200 bg-white shadow-sm" aria-label="<%= t("views.users.show.avatar_placeholder", name: @user.name) %>">
              <span class="text-2xl font-bold text-gray-700"><%= @user.name.first %></span>
            </div>
          <% end %>

          <div class="min-w-0 flex-1">
            <p class="mb-2 block text-sm font-semibold text-[#5a3318]"><%= t("views.profiles.edit.avatar") %></p>
            <div class="flex min-w-0 flex-col gap-2 sm:flex-row sm:items-center">
              <%= f.file_field :avatar,
                               accept: "image/jpeg,image/png,image/webp",
                               data: { image_crop_target: "input", action: "change->image-crop#select" },
                               class: "sr-only" %>
              <%= f.label :avatar,
                          t("views.profiles.edit.choose_avatar"),
                          class: "inline-flex cursor-pointer items-center justify-center rounded-lg bg-amber-50 px-4 py-2.5 text-sm font-semibold text-amber-700 transition-colors hover:bg-amber-100" %>
            </div>
          </div>
        </div>

        <%= render "shared/image_crop_modal",
                   title_id: "avatar-image-crop-title",
                   title: t("views.shared.image_crop.title") %>
      </section>

      <section class="rounded-2xl border border-gray-200 bg-white px-4 py-5">
        <%= f.label :name, User.human_attribute_name(:name), class: "mb-2 block text-sm font-semibold text-[#5a3318]" %>
        <%= f.text_field :name,
                         placeholder: t("views.profiles.edit.name_placeholder"),
                         required: true,
                         maxlength: 50,
                         class: "w-full rounded-xl border border-gray-200 bg-white px-3 py-3 text-sm text-gray-900 focus:border-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
      </section>

      <div class="grid grid-cols-2 gap-3 border-t border-gray-200 pt-4">
        <%= link_to t("views.common.cancel"), mypage_path, class: "rounded-2xl border border-amber-100 bg-white px-4 py-3 text-center text-sm font-semibold text-gray-700 transition-colors hover:bg-amber-50" %>
        <%= f.submit t("views.common.update"),
                     data: { form_submit_target: "submitButton" },
                     class: "rounded-2xl bg-amber-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-amber-700 disabled:cursor-not-allowed disabled:opacity-70" %>
      </div>
    <% end %>
  </div>
</div>
