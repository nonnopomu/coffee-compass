<div data-flavor-selector-target="detailPanel" class="<%= detail_mode_selected ? "" : "hidden" %> space-y-3">
  <% circled_counts = {
    1 => "①",
    2 => "②",
    3 => "③",
    4 => "④",
    5 => "⑤",
    6 => "⑥",
    7 => "⑦",
    8 => "⑧",
    9 => "⑨"
  } %>

  <div>
    <p class="text-sm font-semibold text-gray-800">
      <%= t("views.drink_logs.form.detailed_taste_limit_before") %><span class="text-amber-700"><%= t("views.drink_logs.form.detailed_taste_limit") %></span><%= t("views.drink_logs.form.detailed_taste_limit_after") %>
    </p>
    <p class="mt-2 hidden text-xs font-semibold text-amber-700" data-flavor-selector-target="detailLimitMessage">
      <%= t("views.drink_logs.form.detailed_taste_limit_message") %>
    </p>
  </div>

  <div class="space-y-3">
    <% taste_tags.each do |parent_tag| %>
      <% active_children = parent_tag.children.select(&:is_active?).sort_by { |child| [ child.display_order, child.name ] } %>
      <% parent_color_hex = parent_tag.color_hex.to_s.match?(/\A#[0-9a-fA-F]{6}\z/) ? parent_tag.color_hex : "#D99A2B" %>
      <% group_selected = selected_taste_tag_ids.include?(parent_tag.id) || active_children.any? { |child| selected_taste_tag_ids.include?(child.id) } %>
      <% selected_child_count = active_children.count { |child| selected_taste_tag_ids.include?(child.id) } %>
      <% children_id = "detail_taste_children_#{parent_tag.id}" %>

      <section class="rounded-2xl border border-gray-200 border-l-4 bg-white p-3"
               style="--parent-color: <%= parent_color_hex %>; border-left-color: <%= parent_color_hex %>;">
        <button type="button"
                class="flex w-full cursor-pointer items-center justify-between gap-3 py-1 text-left text-sm font-semibold text-gray-900 focus:outline-none focus:ring-2 focus:ring-amber-100"
                aria-expanded="<%= detail_mode_selected && group_selected %>"
                aria-controls="<%= children_id %>"
                data-flavor-selector-target="detailAccordionButton"
                data-flavor-group-id="<%= parent_tag.id %>"
                data-action="flavor-selector#toggleDetailGroup">
          <span class="flex min-w-0 items-center gap-2">
            <span class="h-2.5 w-2.5 shrink-0 rounded-full" style="background-color: <%= parent_color_hex %>;"></span>
            <span class="truncate"><%= parent_tag.name %></span>
          </span>
          <span class="flex shrink-0 items-center gap-2">
            <span class="<%= selected_child_count.zero? ? "hidden" : "inline-flex" %> items-center justify-center text-base font-bold leading-none"
                  style="color: <%= parent_color_hex %>;"
                  data-flavor-selector-target="detailSelectedCount"
                  data-flavor-group-id="<%= parent_tag.id %>"><%= selected_child_count.zero? ? "" : circled_counts.fetch(selected_child_count, selected_child_count) %></span>
            <span class="text-lg leading-none text-gray-400 transition-transform"
                  data-flavor-selector-target="detailAccordionIcon"
                  data-flavor-group-id="<%= parent_tag.id %>"
                  aria-hidden="true">⌄</span>
          </span>
        </button>

        <% if active_children.any? %>
          <div id="<%= children_id %>"
               data-flavor-selector-target="detailChildren"
               data-flavor-group-id="<%= parent_tag.id %>"
               class="<%= "hidden" unless detail_mode_selected && group_selected %> mt-3 flex flex-wrap gap-2 border-t pt-3"
               style="border-top-color: color-mix(in srgb, <%= parent_color_hex %> 35%, #e5e7eb);">
            <% active_children.each do |child_tag| %>
              <% child_color_hex = child_tag.color_hex.to_s.match?(/\A#[0-9a-fA-F]{6}\z/) ? child_tag.color_hex : parent_color_hex %>
              <%= label_tag "detail_taste_tag_#{child_tag.id}",
                            class: "taste-detail-chip inline-flex cursor-pointer items-center gap-2 rounded-full border px-3 py-2 text-sm font-medium",
                            style: "--tag-color: #{child_color_hex};" do %>
                <%= check_box_tag "drink_log[taste_tag_ids][]",
                                  child_tag.id,
                                  selected_taste_tag_ids.include?(child_tag.id),
                                  id: "detail_taste_tag_#{child_tag.id}",
                                  class: "sr-only",
                                  data: {
                                    flavor_selector_target: "detailCheckbox",
                                    action: "change->flavor-selector#toggleDetail",
                                    flavor_group_id: parent_tag.id,
                                    flavor_tag_name: child_tag.name
                                  } %>
                <span class="h-2 w-2 rounded-full" style="background-color: <%= child_color_hex %>;"></span>
                <span><%= child_tag.name %></span>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>
  </div>

  <div class="flex justify-end text-xs"
       aria-label="<%= t("views.drink_logs.form.taste_record_method") %>">
    <button type="button"
            data-flavor-selector-target="modeSwitchButton"
            data-action="flavor-selector#toggleMode"
            class="inline-flex cursor-pointer items-center gap-1 rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-[#5a3318] shadow-sm transition-colors hover:border-amber-300 hover:bg-[#fffaf5] focus:outline-none focus:ring-2 focus:ring-amber-100"
            aria-label="<%= t("views.drink_logs.form.image_taste_mode") %>">
      <span data-flavor-selector-target="modeSwitchLabel">
        <%= t("views.drink_logs.form.image_taste_mode") %>
      </span>
      <span class="text-amber-700" aria-hidden="true">→</span>
    </button>
  </div>
</div>
