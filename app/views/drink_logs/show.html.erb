<% content_for :page_title, t("views.drink_logs.show.page_title") %>
<% content_for :back_path, @safe_back_path %>

<div class="min-h-full bg-gray-50">
  <div class="border-b border-gray-200 bg-white px-4 py-5">
    <p class="text-xs font-medium text-amber-600"><%= @drink_log.cafe.name %></p>
    <h1 class="mt-2 text-xl font-bold text-gray-900"><%= @drink_log.menu_name %></h1>
    <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500">
      <span><%= l(@drink_log.drank_on, format: :long) %></span>
      <span><%= t("views.drink_logs.show.author", name: @drink_log.user.name) %></span>
    </div>
  </div>

  <div class="px-4 py-5 space-y-6">
    <section class="space-y-4">
      <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
        <h2 class="text-sm font-semibold text-gray-900"><%= t("views.drink_logs.show.record_heading") %></h2>
      </div>

      <div class="divide-y divide-gray-100 rounded-lg border border-gray-200 bg-white">
        <div class="flex items-start justify-between gap-4 px-4 py-3">
          <p class="text-sm text-gray-500"><%= t("views.drink_logs.show.cafe") %></p>
          <%= link_to @drink_log.cafe.name, @safe_back_path, class: "text-right text-sm font-semibold text-amber-700" %>
        </div>

        <div class="flex items-start justify-between gap-4 px-4 py-3">
          <p class="text-sm text-gray-500"><%= DrinkLog.human_attribute_name(:menu_name) %></p>
          <p class="text-right text-sm font-semibold text-gray-900"><%= @drink_log.menu_name %></p>
        </div>

        <div class="flex items-start justify-between gap-4 px-4 py-3">
          <p class="text-sm text-gray-500"><%= DrinkLog.human_attribute_name(:drank_on) %></p>
          <p class="text-right text-sm font-semibold text-gray-900"><%= l(@drink_log.drank_on, format: :long) %></p>
        </div>

        <div class="flex items-start justify-between gap-4 px-4 py-3">
          <p class="text-sm text-gray-500"><%= DrinkLog.human_attribute_name(:roast_level_tag) %></p>
          <p class="text-right text-sm font-semibold text-gray-900"><%= @drink_log.roast_level_tag.name %></p>
        </div>

        <div class="flex items-start justify-between gap-4 px-4 py-3">
          <p class="text-sm text-gray-500"><%= DrinkLog.human_attribute_name(:brew_method_tag) %></p>
          <p class="text-right text-sm font-semibold text-gray-900"><%= @drink_log.brew_method_tag.name %></p>
        </div>
      </div>
    </section>

    <section class="space-y-4">
      <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
        <h2 class="text-sm font-semibold text-gray-900"><%= t("views.drink_logs.form.taste") %></h2>
      </div>

      <div class="flex flex-wrap gap-2">
        <% @drink_log.taste_tags.each do |tag| %>
          <span class="rounded-full border border-amber-200 bg-amber-50 px-3 py-1.5 text-sm font-medium text-amber-700"><%= tag.name %></span>
        <% end %>
      </div>
    </section>

    <section class="space-y-4">
      <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
        <h2 class="text-sm font-semibold text-gray-900"><%= t("views.drink_logs.form.memo") %></h2>
      </div>

      <div class="rounded-lg border border-gray-200 bg-white px-4 py-4">
        <% if @drink_log.memo.present? %>
          <p class="whitespace-pre-wrap text-sm leading-6 text-gray-700"><%= @drink_log.memo %></p>
        <% else %>
          <p class="text-sm text-gray-500"><%= t("views.drink_logs.show.no_memo") %></p>
        <% end %>
      </div>
    </section>

    <% if user_signed_in? && @drink_log.user == current_user %>
      <section class="space-y-3">
        <%= link_to t("views.common.edit_action"), edit_drink_log_path(@drink_log), class: "block w-full rounded-lg border border-amber-600 bg-white px-4 py-3 text-center text-sm font-semibold text-amber-700" %>
        <%= link_to t("views.common.delete_action"),
                    drink_log_path(@drink_log, return_to: @safe_back_path),
                    data: { turbo_method: :delete, turbo_confirm: t("views.common.delete_log_confirm") },
                    class: "block w-full rounded-lg border border-red-200 bg-white px-4 py-3 text-center text-sm font-semibold text-red-600" %>
      </section>
    <% end %>

    <div class="pb-6">
      <%= link_to t("views.drink_logs.show.back_to_cafe"), @safe_back_path, class: "block w-full rounded-lg bg-amber-600 px-4 py-3 text-center text-sm font-semibold text-white" %>
    </div>
  </div>
</div>
