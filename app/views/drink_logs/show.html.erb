<% content_for :page_title, t("views.drink_logs.show.page_title") %>
<% content_for :back_path, @safe_back_path %>
<% content_for :page_bg, "bg-white sm:bg-amber-50" %>

<div class="flex flex-1 flex-col bg-white sm:items-center sm:bg-amber-50 sm:px-5 sm:pt-6 sm:pb-8">
  <div class="w-full bg-white px-4 py-5 sm:max-w-md sm:rounded-3xl sm:border sm:border-amber-100 sm:px-5 sm:py-6 sm:shadow-[0_4px_18px_rgba(90,51,24,0.08)]">
    <div class="border-b border-gray-200 pb-5">
    <p class="text-xs font-medium text-amber-600"><%= @drink_log.brewed_at_home? ? t("views.drink_logs.home_brewed_place") : @drink_log.cafe.name %></p>
    <h1 class="mt-2 text-xl font-bold text-[#5a3318]"><%= @drink_log.menu_name %></h1>
    <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500">
      <span><%= l(@drink_log.drank_on, format: :long) %></span>
      <span>
        <%= t("views.drink_logs.show.author_label") %>:
        <%= link_to @drink_log.user.name, user_path(@drink_log.user), class: "font-semibold text-amber-700" %>
      </span>
    </div>
    </div>

    <div class="space-y-6 pt-5">
    <% if @drink_log.image.attached? %>
      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-[#5a3318]"><%= DrinkLog.human_attribute_name(:image) %></h2>
        </div>

        <%= image_tag @drink_log.image,
                      alt: @drink_log.menu_name,
                      class: "aspect-video w-full rounded-2xl border border-gray-200 object-cover",
                      decoding: "async",
                      width: 960,
                      height: 540 %>
      </section>
    <% end %>

    <section class="space-y-4">
      <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
        <h2 class="text-sm font-semibold text-[#5a3318]"><%= t("views.drink_logs.show.record_heading") %></h2>
      </div>

      <div class="divide-y divide-gray-100 rounded-2xl border border-gray-200 bg-white">
        <div class="flex items-start justify-between gap-4 px-4 py-3">
          <p class="text-sm text-gray-500"><%= t("views.drink_logs.show.place") %></p>
          <% if @drink_log.brewed_at_home? %>
            <p class="text-right text-sm font-semibold text-gray-900"><%= t("views.drink_logs.home_brewed_place") %></p>
          <% else %>
            <%= link_to @drink_log.cafe.name, @safe_back_path, class: "text-right text-sm font-semibold text-amber-700" %>
          <% end %>
        </div>

        <div class="flex items-start justify-between gap-4 px-4 py-3">
          <p class="text-sm text-gray-500"><%= DrinkLog.human_attribute_name(:menu_name) %></p>
          <p class="text-right text-sm font-semibold text-gray-900"><%= @drink_log.menu_name %></p>
        </div>

        <div class="flex items-start justify-between gap-4 px-4 py-3">
          <p class="text-sm text-gray-500"><%= DrinkLog.human_attribute_name(:drank_on) %></p>
          <p class="text-right text-sm font-semibold text-gray-900"><%= l(@drink_log.drank_on, format: :long) %></p>
        </div>

        <div class="flex items-start justify-between gap-4 px-4 py-3">
          <p class="text-sm text-gray-500"><%= DrinkLog.human_attribute_name(:roast_level_tag) %></p>
          <p class="text-right text-sm font-semibold text-gray-900"><%= @drink_log.roast_level_tag.name %></p>
        </div>

      </div>
    </section>

    <section class="space-y-4">
      <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
        <h2 class="text-sm font-semibold text-[#5a3318]"><%= t("views.drink_logs.form.taste") %></h2>
      </div>

      <div class="flex flex-wrap gap-2">
        <% @drink_log.ordered_taste_tags.each do |tag| %>
          <%= render "shared/taste_tag_badge", tag: tag %>
        <% end %>
      </div>
    </section>

    <section class="space-y-4">
      <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
        <h2 class="text-sm font-semibold text-[#5a3318]"><%= t("views.drink_logs.form.memo") %></h2>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white px-4 py-4">
        <% if @drink_log.memo.present? %>
          <p class="whitespace-pre-wrap text-sm leading-6 text-gray-700"><%= @drink_log.memo %></p>
        <% else %>
          <p class="text-sm text-gray-500"><%= t("views.drink_logs.show.no_memo") %></p>
        <% end %>
      </div>
    </section>

    </div>
  </div>
</div>
