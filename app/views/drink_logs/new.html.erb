<% content_for :page_title, t("views.drink_logs.new.page_title") %>
<% content_for :back_path, @cafe.present? ? cafe_path(@cafe) : root_path %>
<% content_for :page_bg, "bg-white sm:bg-amber-50" %>

<div class="flex flex-1 flex-col bg-white sm:items-center sm:bg-amber-50 sm:px-5 sm:pt-6 sm:pb-8">
  <div class="w-full overflow-hidden bg-white px-4 py-5 sm:max-w-md sm:rounded-3xl sm:border sm:border-amber-100 sm:px-5 sm:py-6 sm:shadow-[0_4px_18px_rgba(90,51,24,0.08)]">
    <%= form_with model: @drink_log,
                  url: drink_logs_path,
                  method: :post,
                  data: {
                    controller: [(@cafe.present? ? nil : "home-brew-toggle"), "form-submit"].compact.join(" "),
                    action: "turbo:submit-start->form-submit#disable",
                    form_submit_disabled_text_value: t("views.common.submitting")
                  },
                  class: "space-y-6" do |f| %>
      <% if @cafe.present? %>
        <div class="border-b border-gray-200 pb-5">
          <div class="flex items-center gap-3">
            <% if @cafe.image.attached? %>
              <%= image_tag @cafe.image,
                            alt: @cafe.name,
                            class: "h-14 w-14 rounded-2xl border border-amber-100 object-cover",
                            decoding: "async",
                            width: 160,
                            height: 160 %>
            <% else %>
              <%= image_tag "cafe_placeholder.webp",
                            alt: "",
                            class: "h-14 w-14 rounded-2xl border border-amber-100 object-cover",
                            decoding: "async",
                            width: 160,
                            height: 160 %>
            <% end %>

            <div class="min-w-0">
              <h1 class="break-words text-lg font-bold text-gray-900"><%= @cafe.name %></h1>
              <p class="mt-1 break-words text-sm text-gray-600"><%= @cafe.address %></p>
            </div>
          </div>
        </div>
      <% else %>
        <div class="-mx-4 -mt-5 border-b border-gray-200 sm:-mx-5 sm:-mt-6">
          <div class="grid grid-cols-2 bg-gray-50">
            <label class="cursor-pointer">
              <%= f.radio_button :brewed_at_home,
                                 "0",
                                 checked: !@drink_log.brewed_at_home?,
                                 data: { home_brew_toggle_target: "mode", action: "home-brew-toggle#toggle" },
                                 class: "peer sr-only" %>
              <span class="flex min-h-14 items-center justify-center border-b-2 border-transparent px-3 text-center text-sm font-semibold text-gray-500 transition-colors peer-checked:border-amber-600 peer-checked:bg-white peer-checked:text-amber-800 peer-checked:shadow-sm">
                <%= t("views.drink_logs.new.cafe_mode_label") %>
              </span>
            </label>
            <label class="cursor-pointer">
              <%= f.radio_button :brewed_at_home,
                                 "1",
                                 checked: @drink_log.brewed_at_home?,
                                 data: { home_brew_toggle_target: "mode", action: "home-brew-toggle#toggle" },
                                 class: "peer sr-only" %>
              <span class="flex min-h-14 items-center justify-center border-b-2 border-transparent px-3 text-center text-sm font-semibold text-gray-500 transition-colors peer-checked:border-amber-600 peer-checked:bg-white peer-checked:text-amber-800 peer-checked:shadow-sm">
                <%= t("views.drink_logs.new.home_brew_mode_label") %>
              </span>
            </label>
          </div>
        </div>
      <% end %>

      <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>

      <div class="space-y-6 pt-5">
      <% if @drink_log.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3">
          <p class="text-sm font-semibold text-red-700"><%= t("views.common.error_heading") %></p>
          <ul class="mt-2 space-y-1">
            <% @drink_log.errors.full_messages.each do |message| %>
              <li class="text-sm text-red-700"><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <section class="space-y-4"
               data-controller="image-crop"
               data-image-crop-output-width-value="1280"
               data-image-crop-output-height-value="720"
               data-image-crop-quality-value="0.82"
               data-image-crop-file-name-value="drink_log_image"
               data-image-crop-load-error-value="<%= t("views.shared.image_crop.load_error") %>"
               data-image-crop-process-error-value="<%= t("views.shared.image_crop.process_error") %>">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-[#5a3318]"><%= t("views.drink_logs.form.image") %></h2>
        </div>

        <div class="rounded-2xl border border-gray-200 bg-white px-4 py-4">
          <%= f.file_field :image,
                           accept: "image/jpeg,image/png,image/webp",
                           data: { image_crop_target: "input", action: "change->image-crop#select" },
                           class: "sr-only" %>
          <%= hidden_field_tag "drink_log[remove_image]", "0", data: { image_crop_target: "removeField" } %>
          <%= f.label :image, class: "block cursor-pointer overflow-hidden rounded-2xl border border-dashed border-gray-200 bg-gray-50/70" do %>
            <img data-image-crop-target="image"
                 alt="<%= t("views.drink_logs.form.image_preview_alt") %>"
                 class="hidden h-48 w-full object-cover"
                 decoding="async"
                 width="640"
                 height="360">
            <div data-image-crop-target="placeholder" class="flex h-48 items-center justify-center px-4 text-center text-sm font-semibold text-[#5a3318]">
              <%= t("views.drink_logs.form.image_preview_placeholder") %>
            </div>
          <% end %>
          <button type="button"
                  data-image-crop-target="removeButton"
                  data-action="image-crop#remove"
                  class="mt-3 hidden text-sm font-semibold text-red-600">
            <%= t("views.drink_logs.form.remove_image") %>
          </button>
          <% if @cafe.present? %>
            <p class="mt-2 text-xs leading-5 text-gray-500"><%= t("views.drink_logs.form.image_help") %></p>
          <% else %>
            <p data-home-brew-toggle-target="cafeImageHelp" class="mt-2 text-xs leading-5 text-gray-500"><%= t("views.drink_logs.form.image_help") %></p>
            <p data-home-brew-toggle-target="homeImageHelp" class="mt-2 hidden text-xs leading-5 text-gray-500"><%= t("views.drink_logs.form.home_brew_image_help") %></p>
          <% end %>
        </div>

        <%= render "shared/image_crop_modal",
                   title_id: "drink-log-image-crop-title-new",
                   title: t("views.shared.image_crop.title") %>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-[#5a3318]"><%= t("views.drink_logs.form.basic_info") %></h2>
        </div>

        <% if @cafe.present? %>
          <%= f.hidden_field :cafe_id, value: @drink_log.cafe_id || @cafe.id %>
        <% else %>
          <div data-controller="cafe-selection"
               class="space-y-3"
               data-cafe-selection-no-results-message-value="<%= t("views.common.no_matching_cafes") %>">
            <div data-home-brew-toggle-target="cafeFields">
              <%= f.hidden_field :cafe_id, data: { cafe_selection_target: "value", home_brew_toggle_target: "cafeValue" } %>

              <label for="drink_log_cafe_search" class="mb-1 flex items-center gap-2 text-sm font-medium text-gray-700">
                <%= t("views.drink_logs.new.cafe_label") %>
                <span class="text-sm font-semibold text-amber-700" aria-label="<%= t("views.common.required") %>">*</span>
              </label>
              <input id="drink_log_cafe_search"
                     type="search"
                     autocomplete="off"
                     data-cafe-selection-target="query"
                     data-home-brew-toggle-target="query"
                     data-action="input->cafe-selection#filter"
                     class="w-full rounded-xl border border-gray-200 bg-white px-3 py-3 text-sm text-gray-900 focus:border-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-100"
                     placeholder="<%= t("views.drink_logs.new.cafe_search_placeholder") %>">

              <div data-cafe-selection-target="selected" data-home-brew-toggle-target="selected" class="mt-3 hidden rounded-2xl border border-gray-200 bg-amber-50 px-4 py-3">
                <p class="text-xs font-semibold text-amber-700"><%= t("views.drink_logs.new.selected_cafe") %></p>
                <div class="mt-2 flex items-center gap-3">
                  <img data-cafe-selection-target="selectedImage"
                       alt=""
                       class="h-14 w-14 rounded-2xl border border-gray-200 object-cover"
                       decoding="async"
                       width="160"
                       height="160">
                  <div class="min-w-0">
                    <p data-cafe-selection-target="selectedName" class="break-words text-sm font-bold text-gray-900"></p>
                    <p data-cafe-selection-target="selectedAddress" class="mt-1 break-words text-xs text-gray-600"></p>
                  </div>
                </div>
              </div>

              <div data-cafe-selection-target="results" data-home-brew-toggle-target="results" class="mt-2 hidden overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
                <p data-cafe-selection-target="message" data-home-brew-toggle-target="message" class="px-4 py-3 text-sm text-gray-500"></p>
                <% @cafes.each do |cafe| %>
                  <button type="button"
                          data-cafe-selection-target="option"
                          data-home-brew-toggle-target="option"
                          data-action="click->cafe-selection#select"
                          data-cafe-id="<%= cafe.id %>"
                          data-cafe-name="<%= cafe.name %>"
                          data-cafe-address="<%= cafe.address %>"
                          data-cafe-image-url="<%= cafe.image.attached? ? url_for(cafe.image) : asset_path("cafe_placeholder.webp") %>"
                          data-search="<%= cafe.name.downcase %>"
                          class="hidden w-full border-t border-gray-100 px-4 py-3 text-left">
                    <span class="block text-sm font-semibold text-gray-900"><%= cafe.name %></span>
                    <span class="mt-1 block text-xs text-gray-500"><%= cafe.prefecture %> / <%= cafe.address %></span>
                  </button>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <div>
          <%= f.label :menu_name, class: "mb-1 flex items-center gap-2 text-sm font-medium text-gray-700" do %>
            <%= DrinkLog.human_attribute_name(:menu_name) %>
            <span class="text-sm font-semibold text-amber-700" aria-label="<%= t("views.common.required") %>">*</span>
          <% end %>
          <%= f.text_field :menu_name, required: true, class: "w-full rounded-xl border border-gray-200 bg-white px-3 py-3 text-sm text-gray-900 focus:border-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-100", placeholder: t("views.drink_logs.form.menu_name_placeholder") %>
        </div>

        <div>
          <%= f.label :drank_on, class: "mb-1 flex items-center gap-2 text-sm font-medium text-gray-700" do %>
            <%= DrinkLog.human_attribute_name(:drank_on) %>
            <span class="text-sm font-semibold text-amber-700" aria-label="<%= t("views.common.required") %>">*</span>
          <% end %>
          <%= f.date_field :drank_on,
                           value: @drink_log.drank_on || Date.current,
                           required: true,
                           data: { controller: "date-picker", action: "click->date-picker#open keydown->date-picker#open" },
                           class: "w-full cursor-pointer rounded-xl border border-gray-200 bg-white px-3 py-3 text-sm text-gray-900 focus:border-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-[#5a3318]"><%= t("views.drink_logs.form.roast_level") %></h2>
          <span class="text-sm font-semibold text-amber-700" aria-label="<%= t("views.common.required") %>">*</span>
        </div>

        <div class="grid grid-cols-1 gap-2">
          <% if @roast_level_tags.any? %>
            <%= f.collection_radio_buttons :roast_level_tag_id, @roast_level_tags, :id, :name do |tag_builder| %>
              <%= tag_builder.label class: "flex cursor-pointer items-center gap-3 rounded-2xl border border-gray-200 bg-white px-4 py-3 has-[:checked]:border-amber-600 has-[:checked]:bg-amber-50" do %>
                <%= tag_builder.radio_button class: "h-4 w-4 border-gray-300 text-amber-600 focus:ring-amber-500" %>
                <span class="text-sm font-medium text-gray-900"><%= tag_builder.text %></span>
              <% end %>
            <% end %>
          <% else %>
            <p class="rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-500"><%= t("views.drink_logs.form.no_roast_level_tags") %></p>
          <% end %>
        </div>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-[#5a3318]"><%= t("views.drink_logs.form.taste") %></h2>
          <span class="text-sm font-semibold text-amber-700" aria-label="<%= t("views.common.required") %>">*</span>
        </div>

        <%= render "beginner_taste_selector", f: f, taste_tags: @taste_tags %>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-[#5a3318]"><%= t("views.drink_logs.form.memo") %></h2>
        </div>

        <%= f.text_area :memo, rows: 5, maxlength: 200, class: "w-full resize-y rounded-2xl border border-gray-200 bg-white px-3 py-3 text-sm leading-6 text-gray-900 focus:border-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-100", placeholder: t("views.drink_logs.form.memo_placeholder") %>
      </section>
      </div>

      <div class="grid grid-cols-2 gap-3 border-t border-gray-200 pt-4">
        <%= link_to t("views.common.cancel"), @cafe.present? ? cafe_path(@cafe) : root_path, class: "rounded-2xl border border-gray-200 bg-white px-4 py-3 text-center text-sm font-semibold text-gray-700 transition-colors hover:bg-amber-50" %>
        <%= button_tag t("views.common.post"),
                       type: "submit",
                       data: { form_submit_target: "submitButton" },
                       class: "rounded-2xl bg-amber-600 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-amber-700 disabled:cursor-not-allowed disabled:opacity-70" %>
      </div>
    <% end %>
  </div>
</div>
