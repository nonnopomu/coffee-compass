<% content_for :page_title, "ログ作成" %>
<% content_for :back_path, @cafe.present? ? cafe_path(@cafe) : root_path %>

<div class="min-h-full bg-gray-50">
  <div class="border-b border-gray-200 bg-white px-4 py-4">
    <% if @cafe.present? %>
      <p class="text-xs text-gray-500">記録するカフェ</p>
      <h1 class="mt-1 text-lg font-bold text-gray-900"><%= @cafe.name %></h1>
      <p class="mt-1 text-sm text-gray-600"><%= @cafe.address %></p>
    <% else %>
      <p class="text-xs text-gray-500">ログを記録</p>
      <h1 class="mt-1 text-lg font-bold text-gray-900">カフェを選択して記録する</h1>
      <p class="mt-1 text-sm text-gray-600">登録済みのカフェから、ログを残す店舗を選んでください。</p>
    <% end %>
  </div>

  <%= form_with model: @drink_log, url: "#", method: :post, class: "flex flex-col" do |f| %>
    <div class="px-4 py-5 space-y-6">
      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-gray-900">基本情報</h2>
        </div>

        <% if @cafe.present? %>
          <%= f.hidden_field :cafe_id, value: @cafe.id %>
        <% else %>
          <div data-controller="cafe-selection">
            <%= f.hidden_field :cafe_id, data: { cafe_selection_target: "value" } %>

            <label for="drink_log_cafe_search" class="mb-1 block text-sm font-medium text-gray-700">カフェ</label>
            <input id="drink_log_cafe_search"
                   type="search"
                   autocomplete="off"
                   data-cafe-selection-target="query"
                   data-action="input->cafe-selection#filter"
                   class="w-full rounded-lg border border-gray-200 bg-white px-3 py-3 text-sm text-gray-900 focus:border-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-100"
                   placeholder="カフェ名で検索">

            <div data-cafe-selection-target="selected" class="mt-3 hidden rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
              <p class="text-xs font-semibold text-amber-700">選択中のカフェ</p>
              <p data-cafe-selection-target="selectedName" class="mt-1 text-sm font-bold text-gray-900"></p>
              <p data-cafe-selection-target="selectedAddress" class="mt-1 text-xs text-gray-600"></p>
            </div>

            <div class="mt-2 overflow-hidden rounded-lg border border-gray-200 bg-white">
              <p data-cafe-selection-target="message" class="px-4 py-3 text-sm text-gray-500"></p>
              <% @cafes.each do |cafe| %>
                <button type="button"
                        data-cafe-selection-target="option"
                        data-action="click->cafe-selection#select"
                        data-cafe-id="<%= cafe.id %>"
                        data-cafe-name="<%= cafe.name %>"
                        data-cafe-address="<%= cafe.address %>"
                        data-search="<%= cafe.name.downcase %>"
                        class="hidden w-full border-t border-gray-100 px-4 py-3 text-left">
                  <span class="block text-sm font-semibold text-gray-900"><%= cafe.name %></span>
                  <span class="mt-1 block text-xs text-gray-500"><%= cafe.prefecture %> / <%= cafe.address %></span>
                </button>
              <% end %>
            </div>
          </div>
        <% end %>

        <div>
          <%= f.label :menu_name, "メニュー名", class: "mb-1 block text-sm font-medium text-gray-700" %>
          <%= f.text_field :menu_name, class: "w-full rounded-lg border border-gray-200 bg-white px-3 py-3 text-sm text-gray-900 focus:border-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-100", placeholder: "例: ハンドドリップ" %>
        </div>

        <div>
          <%= f.label :drank_on, "飲んだ日", class: "mb-1 block text-sm font-medium text-gray-700" %>
          <%= f.date_field :drank_on, value: Date.current, class: "w-full rounded-lg border border-gray-200 bg-white px-3 py-3 text-sm text-gray-900 focus:border-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-100" %>
        </div>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-gray-900">焙煎度</h2>
        </div>

        <div class="grid grid-cols-1 gap-2">
          <% if @roast_level_tags.any? %>
            <%= f.collection_radio_buttons :roast_level_tag_id, @roast_level_tags, :id, :name do |tag_builder| %>
              <%= tag_builder.label class: "flex cursor-pointer items-center gap-3 rounded-lg border border-gray-200 bg-white px-4 py-3 has-[:checked]:border-amber-600 has-[:checked]:bg-amber-50" do %>
                <%= tag_builder.radio_button class: "h-4 w-4 border-gray-300 text-amber-600 focus:ring-amber-500" %>
                <span class="text-sm font-medium text-gray-900"><%= tag_builder.text %></span>
              <% end %>
            <% end %>
          <% else %>
            <p class="rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-500">選択できる焙煎度タグがありません</p>
          <% end %>
        </div>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-gray-900">味わい</h2>
        </div>

        <div class="flex flex-wrap gap-2">
          <%= f.hidden_field :taste_tag_ids, multiple: true, value: "" %>
          <% if @taste_tags.any? %>
            <%= f.collection_check_boxes :taste_tag_ids, @taste_tags, :id, :name, include_hidden: false do |tag_builder| %>
              <%= tag_builder.label class: "inline-flex cursor-pointer items-center gap-2 rounded-full border border-gray-200 bg-white px-3 py-2 text-sm text-gray-700 has-[:checked]:border-amber-600 has-[:checked]:bg-amber-50 has-[:checked]:text-amber-700" do %>
                <%= tag_builder.check_box class: "h-4 w-4 rounded border-gray-300 text-amber-600 focus:ring-amber-500" %>
                <span><%= tag_builder.text %></span>
              <% end %>
            <% end %>
          <% else %>
            <p class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-500">選択できる味わいタグがありません</p>
          <% end %>
        </div>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-gray-900">提供スタイル</h2>
        </div>

        <div class="grid grid-cols-1 gap-2">
          <% if @brew_method_tags.any? %>
            <%= f.collection_radio_buttons :brew_method_tag_id, @brew_method_tags, :id, :name do |tag_builder| %>
              <%= tag_builder.label class: "flex cursor-pointer items-center gap-3 rounded-lg border border-gray-200 bg-white px-4 py-3 has-[:checked]:border-amber-600 has-[:checked]:bg-amber-50" do %>
                <%= tag_builder.radio_button class: "h-4 w-4 border-gray-300 text-amber-600 focus:ring-amber-500" %>
                <span class="text-sm font-medium text-gray-900"><%= tag_builder.text %></span>
              <% end %>
            <% end %>
          <% else %>
            <p class="rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-gray-500">選択できる提供スタイルタグがありません</p>
          <% end %>
        </div>
      </section>

      <section class="space-y-4">
        <div class="flex items-center gap-2 border-l-4 border-amber-600 pl-3">
          <h2 class="text-sm font-semibold text-gray-900">感想メモ</h2>
        </div>

        <%= f.text_area :memo, rows: 5, maxlength: 200, class: "w-full resize-y rounded-lg border border-gray-200 bg-white px-3 py-3 text-sm leading-6 text-gray-900 focus:border-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-100", placeholder: "味の印象やまた飲みたい理由など" %>
      </section>
    </div>

    <div class="sticky bottom-0 border-t border-gray-200 bg-white px-4 py-3">
      <div class="mx-auto flex max-w-screen-sm gap-3">
        <%= link_to "キャンセル", @cafe.present? ? cafe_path(@cafe) : root_path, class: "flex-1 rounded-lg border border-gray-200 bg-white px-4 py-3 text-center text-sm font-medium text-gray-700" %>
        <%= button_tag "投稿する", type: "button", class: "flex-1 rounded-lg bg-amber-600 px-4 py-3 text-sm font-semibold text-white" %>
      </div>
    </div>
  <% end %>
</div>
