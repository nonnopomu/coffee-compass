<% unless content_for?(:hide_footer) || controller_path.start_with?("admin/") %>
  <% image_footer = content_for?(:image_footer) %>

  <% if image_footer %>
    <footer class="relative overflow-hidden px-4 py-5">
      <div class="relative flex w-full items-center justify-end gap-2.5 text-[11px] text-[#5a3318]">
        <%= link_to t("views.shared.footer.terms"),
                    terms_path,
                    class: "rounded-md border border-white/70 bg-white/30 px-2.5 py-1.5 font-semibold shadow-sm backdrop-blur-sm hover:bg-white/50" %>
        <%= link_to t("views.shared.footer.privacy"),
                    privacy_path,
                    class: "rounded-md border border-white/70 bg-white/30 px-2.5 py-1.5 font-semibold shadow-sm backdrop-blur-sm hover:bg-white/50" %>
      </div>
    </footer>
  <% end %>

  <% if user_signed_in? %>
    <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-10">
      <div class="max-w-screen-sm mx-auto flex items-center justify-around h-16">

        <%= link_to root_path, class: "flex flex-col items-center gap-1 text-gray-400 hover:text-amber-600 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="text-xs font-medium"><%= t("views.shared.footer.search_cafes") %></span>
        <% end %>

        <% drink_log_path = controller_path == "cafes" && action_name == "show" && @cafe.present? ? new_cafe_drink_log_path(@cafe) : new_drink_log_path %>
        <%= link_to drink_log_path, class: "flex flex-col items-center gap-1 text-gray-400 hover:text-amber-600 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          <span class="text-xs font-medium"><%= t("views.shared.footer.record_log") %></span>
        <% end %>

        <%= link_to mypage_path, class: "flex flex-col items-center gap-1 text-gray-400 hover:text-amber-600 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <span class="text-xs font-medium"><%= t("views.shared.footer.mypage") %></span>
        <% end %>

      </div>
    </nav>
    <div class="h-16"></div>
  <% end %>
<% end %>
