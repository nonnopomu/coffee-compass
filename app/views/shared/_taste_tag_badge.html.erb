<% color_hex = tag.color_hex.to_s.match?(/\A#[0-9a-fA-F]{6}\z/) ? tag.color_hex : "#D99A2B" %>
<% size_class = local_assigns.fetch(:size, :sm).to_sym == :xs ? "px-2.5 py-1 text-xs" : "px-3 py-1.5 text-sm" %>

<span class="rounded-full border font-medium <%= size_class %>"
      style="border-color: color-mix(in srgb, <%= color_hex %> 45%, #ffffff); background-color: color-mix(in srgb, <%= color_hex %> 14%, #ffffff); color: color-mix(in srgb, <%= color_hex %> 65%, #3f2a1d);">
  <%= tag.name %>
</span>
