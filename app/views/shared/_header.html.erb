<% transparent_header = content_for?(:transparent_header) %>

<header class="<%= transparent_header ? 'absolute left-0 right-0 top-0 z-20 bg-transparent px-4 py-3 sm:px-6 lg:px-8' : 'sticky top-0 z-10 border-b border-gray-200 bg-white px-4 py-3 sm:px-6 lg:px-8' %>">
  <div class="flex min-h-8 items-center gap-3">
    <% if content_for?(:back_path) %>
      <div class="flex shrink-0 items-center">
      <%= link_to yield(:back_path), class: "text-gray-600" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>
      </div>
    <% end %>

    <div class="min-w-0 flex-1 <%= content_for?(:header_center) ? 'text-left' : 'text-center' %>">
      <div class="inline-flex max-w-full items-center <%= content_for?(:header_center) ? 'justify-start' : 'justify-center' %>">
        <% if content_for?(:header_center) %>
          <%= yield :header_center %>
        <% else %>
          <span class="truncate text-base font-medium text-gray-900"><%= yield :page_title %></span>
        <% end %>
      </div>
    </div>

    <div class="flex shrink-0 items-center gap-4">
      <% if content_for?(:hide_user_icon) %>
      <% elsif user_signed_in? %>
        <% if current_user.admin? %>
          <% if controller_path.start_with?("admin/") %>
            <%= link_to t("views.shared.header.normal"), root_path, class: "whitespace-nowrap text-xs font-medium text-amber-600" %>
          <% else %>
            <%= link_to t("views.shared.header.admin"), admin_root_path, class: "whitespace-nowrap text-xs font-medium text-amber-600" %>
          <% end %>
        <% end %>
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-amber-600">
          <span class="text-sm font-medium text-white"><%= current_user.name[0] %></span>
        </div>
      <% else %>
        <%= link_to t("views.shared.header.login"), new_user_session_path(return_to: request.fullpath), class: "whitespace-nowrap rounded-lg bg-amber-50/70 px-3 py-2 text-sm font-bold text-[#5a3318] shadow-sm backdrop-blur-sm hover:bg-amber-50" %>
        <%= link_to t("views.shared.header.sign_up"), new_user_registration_path(return_to: request.fullpath), class: "whitespace-nowrap rounded-lg bg-amber-600 px-4 py-2 text-sm font-bold text-white" %>
      <% end %>
    </div>
  </div>
</header>
