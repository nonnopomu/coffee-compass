<% transparent_header = content_for?(:transparent_header) %>

<header class="<%= transparent_header ? 'absolute left-0 right-0 top-0 z-20 border-b border-white/30 bg-transparent px-4 py-3 sm:px-6 lg:px-8' : 'sticky top-0 z-10 border-b border-gray-200 bg-white px-4 py-3 sm:px-6 lg:px-8' %>">
  <div class="relative flex min-h-8 items-center gap-3">
    <div class="flex shrink-0 items-center">
      <div class="relative sm:hidden" data-controller="user-menu" data-action="click@window->user-menu#closeOnOutside keydown@window->user-menu#closeOnEscape">
        <button type="button"
                class="flex h-9 w-9 cursor-pointer flex-col items-center justify-center gap-1.5 rounded-xl transition-shadow hover:ring-2 hover:ring-amber-200 hover:ring-offset-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-300 focus-visible:ring-offset-2"
                aria-label="<%= t("views.shared.header.open_site_menu") %>"
                data-user-menu-target="button"
                data-action="click->user-menu#toggle">
          <span class="block h-0.5 w-5 rounded-full bg-[#5a3318]"></span>
          <span class="block h-0.5 w-5 rounded-full bg-[#5a3318]"></span>
          <span class="block h-0.5 w-5 rounded-full bg-[#5a3318]"></span>
        </button>

        <div class="absolute left-0 top-full z-30 mt-2 hidden w-40 overflow-hidden rounded-xl border border-amber-100 bg-white py-2 shadow-lg"
             data-user-menu-target="menu">
          <%= link_to t("views.shared.header.top"), root_path, class: "block px-4 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:bg-amber-50 hover:text-amber-700" %>
          <% if user_signed_in? %>
            <%= link_to t("views.shared.header.record_log"), new_drink_log_path, class: "block px-4 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:bg-amber-50 hover:text-amber-700" %>
          <% end %>
        </div>
      </div>

      <div class="hidden min-w-0 items-center gap-4 sm:flex">
        <%= link_to root_path, class: "flex min-w-0 items-center gap-2 text-[#5a3318]" do %>
          <div class="h-9 w-9 flex-shrink-0 p-0.5">
            <%= image_tag "coffee_compass_orbit_transparent.webp",
                          alt: t("app.name"),
                          class: "h-full w-full scale-125 object-contain",
                          decoding: "async",
                          width: 512,
                          height: 512 %>
          </div>
          <span class="brand-wordmark truncate text-lg font-bold"><%= t("app.name") %></span>
        <% end %>
        <% if user_signed_in? %>
          <%= link_to t("views.shared.header.record_log"), new_drink_log_path, class: "whitespace-nowrap rounded-lg border border-amber-100 px-3 py-1.5 text-sm font-semibold text-[#5a3318] transition-colors hover:bg-amber-50 hover:text-amber-700" %>
        <% end %>
      </div>
    </div>

    <div class="<%= content_for?(:header_center) ? 'min-w-0 flex-1 text-left' : 'pointer-events-none absolute left-1/2 top-1/2 w-[min(14rem,calc(100%-8rem))] -translate-x-1/2 -translate-y-1/2 text-center sm:w-[min(14rem,calc(100%-18rem))]' %>">
      <div class="inline-flex max-w-full items-center <%= content_for?(:header_center) ? 'justify-start' : 'justify-center' %>">
        <% if content_for?(:header_center) %>
          <%= yield :header_center %>
        <% else %>
          <span class="truncate text-base font-semibold text-[#3f2a1d]"><%= yield :page_title %></span>
        <% end %>
      </div>
    </div>

    <div class="absolute right-0 top-1/2 flex shrink-0 -translate-y-1/2 items-center gap-4">
      <% if content_for?(:hide_user_icon) %>
      <% elsif user_signed_in? %>
        <div class="relative" data-controller="user-menu" data-action="click@window->user-menu#closeOnOutside keydown@window->user-menu#closeOnEscape">
          <button type="button"
                  class="flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-full transition-shadow hover:ring-2 hover:ring-amber-200 hover:ring-offset-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-300 focus-visible:ring-offset-2"
                  aria-label="<%= t("views.shared.header.open_user_menu") %>"
                  data-user-menu-target="button"
                  data-action="click->user-menu#toggle">
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar.variant(resize_to_fill: [ 96, 96 ]),
                            alt: t("views.users.show.avatar_alt", name: current_user.name),
                            class: "h-9 w-9 rounded-full object-cover",
                            decoding: "async",
                            width: 96,
                            height: 96 %>
            <% else %>
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-amber-600 text-sm font-medium text-white"><%= current_user.name[0] %></span>
            <% end %>
          </button>

          <div class="absolute right-0 top-full z-30 mt-2 hidden w-44 overflow-hidden rounded-xl border border-amber-100 bg-white py-2 shadow-lg"
               data-user-menu-target="menu">
            <% if current_user.admin? %>
              <%= link_to t("views.shared.header.admin_dashboard"), admin_root_path, class: "block px-4 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:bg-amber-50 hover:text-amber-700" %>
              <div class="my-1 border-t border-gray-100"></div>
            <% end %>
            <%= link_to t("views.shared.header.mypage"), mypage_path, class: "block px-4 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:bg-amber-50 hover:text-amber-700" %>
            <%= link_to t("views.shared.header.account_settings"), edit_user_registration_path, class: "block px-4 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:bg-amber-50 hover:text-amber-700" %>
            <div class="my-1 border-t border-gray-100"></div>
            <%= link_to t("views.shared.header.logout"),
                        destroy_user_session_path,
                        data: { turbo_method: :delete, turbo_confirm: t("views.shared.header.logout_confirm") },
                        class: "block px-4 py-2.5 text-sm font-medium text-red-600 transition-colors hover:bg-red-50" %>
          </div>
        </div>
      <% elsif transparent_header %>
          <%= link_to t("views.shared.header.login"), new_user_session_path(return_to: request.fullpath), class: "whitespace-nowrap rounded-lg border border-amber-200/80 bg-amber-50/90 px-3.5 py-2 text-xs font-bold text-[#5a3318] shadow-sm backdrop-blur-sm transition-colors hover:bg-amber-100 sm:hidden" %>
          <div class="hidden items-center gap-4 sm:flex">
            <%= link_to t("views.shared.header.login"), new_user_session_path(return_to: request.fullpath), class: "whitespace-nowrap rounded-lg bg-amber-50/70 px-3 py-2 text-sm font-bold text-[#5a3318] shadow-sm backdrop-blur-sm hover:bg-amber-50" %>
            <%= link_to t("views.shared.header.sign_up"), new_user_registration_path(return_to: request.fullpath), class: "whitespace-nowrap rounded-lg bg-amber-600 px-4 py-2 text-sm font-bold text-white" %>
          </div>
      <% end %>
    </div>
  </div>
</header>
