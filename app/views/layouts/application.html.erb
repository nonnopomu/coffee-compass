<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen flex flex-col <%= content_for?(:page_bg) ? yield(:page_bg) : 'bg-white' %>">
    <%= render "shared/header" %>
    <div class="fixed top-16 left-0 right-0 z-50 flex flex-col items-center gap-2 px-4 pointer-events-none">
      <% flash.each do |type, message| %>
        <div data-controller="flash" class="w-full max-w-screen-sm px-4 py-3 rounded-lg text-sm font-medium shadow-md pointer-events-auto <%= type.to_s == 'alert' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
          <%= message %>
        </div>
      <% end %>
    </div>
    <div class="w-full max-w-screen-sm mx-auto flex-1 flex flex-col">
      <%= yield %>
    </div>
    <%= render "shared/footer" %>
  </body>
</html>
